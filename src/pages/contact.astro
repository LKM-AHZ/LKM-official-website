---
import Layout from '~/layouts/SidebarLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: '联系我们',
};

const topTabs = [
  { text: '管理团队', href: getPermalink('/team') },
  { text: '关于我们', href: getPermalink('/about') },
  { text: '服务', href: getPermalink('/services') },
  { text: '赞助与支持', href: getPermalink('/pricing') },
  { text: '联系我们', href: getPermalink('/contact') },
];

const sidebarLinks = [
  { text: '发送消息', href: getPermalink('/contact#form') },
  { text: '联系方式', href: getPermalink('/contact#support') },
];
---

<Layout metadata={metadata} topTabs={topTabs} sidebarLinks={sidebarLinks} currentPath={getPermalink('/contact')}>
  <!-- Hero -->
  <HeroText tagline="联系我们" title="期待听到你的声音！" />

  <!-- 留言表单 -->
  <ContactUs
    id="form"
    title="给我们留言"
    subtitle="如果你想加入理科迷、提出建议或合作意向，欢迎通过下方表单联系我们。也可以先看看常见问题，也许已经有了你想要的答案。"
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: '你的名字',
      },
      {
        type: 'email',
        name: 'email',
        label: '电子邮箱',
      },
    ]}
    textarea={{
      label: '留言内容',
    }}
    disclaimer={{
      label: '提交此表单即表示你同意我们收集你的个人信息用于联系回复。',
    }}
    description="我们通常会在 24 小时内回复你的留言。"
  />

  <!-- 联系方式 -->
  <Features2
    id="support"
    title="联系我们"
    items={[
      {
        title: '加入社区',
        description: '通过官方 QQ 群组加入理科迷，与志同道合的伙伴一起交流。具体群号和入群方式请在留言中咨询。',
        icon: 'tabler:users-group',
      },
      {
        title: '合作建议',
        description: '如果你有科普内容合作、活动联办、技术支持等方面的合作意向，欢迎通过留言表单联系我们。',
        icon: 'tabler:heart-handshake',
      },
      {
        title: '问题反馈',
        description: '网站、文档库或社区的 Bug 反馈与功能建议，都可以通过留言表单提交，我们会认真处理每一条反馈。',
        icon: 'tabler:bug',
      },
      {
        title: '邮箱',
        description: 'almafox123@outlook.com',
        icon: 'tabler:mail',
      },
      {
        title: 'GitHub',
        description: 'github.com/LKM-official',
        icon: 'tabler:brand-github',
      },
      {
        title: 'B站',
        description: '关注官方B站账号获取最新科普视频',
        icon: 'tabler:brand-bilibili',
      },
    ]}
  />
</Layout>
