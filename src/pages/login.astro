---
import PageLayout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: '登录',
};
---

<PageLayout metadata={metadata}>
  <div class="relative min-h-[calc(100vh-12rem)] flex items-center justify-center px-4">
    <!-- 半透明背景遮罩 -->
    <div class="absolute inset-0 bg-base-100/70 backdrop-blur-sm"></div>

    <!-- 悬浮卡片 -->
    <div class="relative w-full max-w-md">
      <div class="rounded-2xl bg-base-100 shadow-2xl border border-base-300 p-6 sm:p-8">
        <!-- 标题 -->
        <div class="text-center mb-6">
          <h1 class="text-3xl md:text-4xl font-semibold leading-tight mb-2 text-base-content">登录</h1>
          <p class="text-sm text-neutral">登录理科迷账号，访问社区资源与文档</p>
        </div>

        <!-- 登录暂未开放提示 -->
        <div class="alert alert-warning mb-5 not-prose">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="stroke-current shrink-0 h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"
            ></path>
          </svg>
          <span class="text-sm"
            >登录功能暂未开放。如需访问请联系<a href={getPermalink('/contact')} class="font-semibold underline"
              >管理团队</a
            >。</span
          >
        </div>

        <!-- 登录表单 -->
        <form id="login-form" novalidate data-contact-url={getPermalink('/contact')}>
          <div id="form-message" class="hidden mb-4" role="alert" aria-live="polite"></div>

          <div class="mb-4">
            <label class="label pb-1" for="username">
              <span class="label-text font-medium">用户名</span>
            </label>
            <input
              type="text"
              id="username"
              name="username"
              autocomplete="username"
              placeholder="请输入用户名"
              class="input input-bordered w-full"
              required
              aria-describedby="username-error"
            />
            <span id="username-error" class="label-text-alt text-error hidden mt-1" role="alert" aria-live="polite"
            ></span>
          </div>

          <div class="mb-4">
            <label class="label pb-1" for="password">
              <span class="label-text font-medium">密码</span>
            </label>
            <input
              type="password"
              id="password"
              name="password"
              autocomplete="current-password"
              placeholder="请输入密码"
              class="input input-bordered w-full"
              required
              minlength="6"
              aria-describedby="password-error"
            />
            <span id="password-error" class="label-text-alt text-error hidden mt-1" role="alert" aria-live="polite"
            ></span>
          </div>

          <div class="mt-8">
            <button type="submit" class="btn btn-primary w-full">登录</button>
          </div>
        </form>

        <p class="text-center text-[13px] text-neutral mt-5">
          需要账号？<a href={getPermalink('/contact')} class="text-primary font-semibold hover:underline"
            >联系管理团队</a
          >
        </p>
      </div>
    </div>
  </div>
</PageLayout>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement | null;
  if (!form) throw new Error('Login form not found');

  const usernameInput = document.getElementById('username') as HTMLInputElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const usernameError = document.getElementById('username-error') as HTMLElement;
  const passwordError = document.getElementById('password-error') as HTMLElement;
  const formMessage = document.getElementById('form-message') as HTMLElement;
  const contactUrl = form.dataset.contactUrl || '/contact';

  function showError(el: HTMLElement, message: string) {
    el.textContent = message;
    el.classList.remove('hidden');
  }

  function hideError(el: HTMLElement) {
    el.textContent = '';
    el.classList.add('hidden');
  }

  function setInputError(input: HTMLInputElement, errorEl: HTMLElement, show: boolean) {
    if (show) {
      input.classList.add('input-error');
    } else {
      input.classList.remove('input-error');
      hideError(errorEl);
    }
  }

  form.addEventListener('submit', function (e: SubmitEvent) {
    e.preventDefault();

    let hasError = false;

    // 验证用户名
    if (!usernameInput.value.trim()) {
      showError(usernameError, '请输入用户名');
      setInputError(usernameInput, usernameError, true);
      hasError = true;
    } else {
      setInputError(usernameInput, usernameError, false);
    }

    // 验证密码
    if (!passwordInput.value) {
      showError(passwordError, '请输入密码');
      setInputError(passwordInput, passwordError, true);
      hasError = true;
    } else if (passwordInput.value.length < 6) {
      showError(passwordError, '密码长度不能少于 6 位');
      setInputError(passwordInput, passwordError, true);
      hasError = true;
    } else {
      setInputError(passwordInput, passwordError, false);
    }

    if (hasError) return;

    // 表单验证通过 — 显示暂未开放提示
    formMessage.className = 'mb-4 alert alert-warning';
    formMessage.innerHTML =
      '<svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg><span>登录功能暂未开放，表单项已验证通过。如需访问请联系<a href="' +
      contactUrl +
      '" class="font-semibold underline">管理团队</a>。</span>';
  });

  // 输入时自动清除错误
  usernameInput.addEventListener('input', function () {
    if (usernameInput.value.trim()) {
      setInputError(usernameInput, usernameError, false);
    }
  });
  passwordInput.addEventListener('input', function () {
    if (passwordInput.value && passwordInput.value.length >= 6) {
      setInputError(passwordInput, passwordError, false);
    }
  });
</script>
