---
import Layout from '~/layouts/Layout.astro';
import { getHomePermalink } from '~/utils/permalinks';

const title = `页面未找到`;
---

<Layout metadata={{ title }}>
  <section class="flex items-center h-full p-16">
    <div class="container flex flex-col items-center justify-center px-5 mx-auto my-8">
      <div class="max-w-md text-center">
        <h2 class="mb-8 font-bold text-9xl">
          <span class="sr-only">错误</span>
          <span class="text-[#0066cc]">404</span>
        </h2>
        <p class="text-[28px] font-semibold">抱歉，找不到此页面。</p>
        <p class="mt-4 mb-8 text-[17px] text-[#7a7a7a] dark:text-[#cccccc]">别担心，返回首页还能找到更多精彩内容。</p>
        <a rel="noopener noreferrer" href={getHomePermalink()} class="btn-primary">返回首页</a>
      </div>
    </div>
  </section>
</Layout>
