---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
// import Note from '~/components/widgets/Note.astro';
// import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';

// import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Timeline from '~/components/widgets/Timeline.astro';
import Section from '~/components/widgets/Section.astro';
// import Stats from '~/components/widgets/Stats.astro';
// import CallToAction from '~/components/widgets/CallToAction.astro';
// import TimelineSection from '~/components/widgets/TimelineSection.astro';
const metadata = {
  title: '理科迷 —— 科技爱好者',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    id="intro"
    actions={[
      {
        variant: 'primary',
        text: '博客',
        href: 'blog',
        target: '_self',
        icon: 'tabler:arrow-right',
      },
      {
        text: 'GitHub',
        href: 'https://github.com/LKM-2014/LKM-official-website',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: '理科迷' }}
  >
    <Fragment slot="title">
      <div class="flex flex-col gap-4">
        <div>
          理科<span class="text-accent dark:text-cyan-100">Phientist</span>迷！
        </div>

        <span class="block mb-1 font-bold dark:text-white-600 tracking-wide"> 科技爱好者社区 </span>
      </div>
    </Fragment>
    <Fragment slot="subtitle">
      <span class="block text-lg font-medium text-slate-900 dark:text-white mb-2">
        由普罗大众组成的科技爱好者社区
      </span>

      <span class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed tracking-wide hidden sm:inline">
        <strong class="font-semibold text-indigo-600 dark:text-indigo-400 mr-1">Here!</strong>
        科学脱离了象牙塔的刻板与高冷，变成了每一个普通人对世界发问的好奇心。我们打破专业门槛，让每一位热爱理性、崇尚科学的“普通人”，都能在这里找到同频的伙伴，共同探索万物运转的奥秘。
      </span>
    </Fragment>
  </Hero>

  <Features2
    id="team"
    title="团队成员"
    subtitle="理科迷因为有你，所以更加精彩"
    tagline="团队成员"
    items={[
      {
        title: '千寻',
        description: '2024年重建理科迷，推动社区第二次复兴',
        icon: '/images/member/千寻.jpg',
      },
      {
        title: '七月花',
        description: '一个有理想的博士，梦想：每个孩子都能接触科学',
        icon: '/images/member/七月花.jpg',
      },
      {
        title: '七月墨染',
        description: '双非物理，卧薪尝胆三千日，大雪深埋终成金',
        icon: '/images/member/千寻.jpg',
      },
      {
        title: '七月A',
        description: '技术委员会成员',
        icon: '/images/member/七月A.jpg',
      },
      {
        title: '七月有枝',
        description: '前活动策划组组员，且停且忘且随风，且行且看且从容',
        icon: '/images/member/千寻.jpg',
      },
      {
        title: '更多成员',
        description: '点击查看完整管理团队',
        icon: '',
        callToAction: { text: '查看全部 →', href: '/team' },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <Section title="发展历程" subtitle="物换星移，春秋代序" tagline="发展历程" id="timeline">
    <div class="flex justify-center"></div>
    <Timeline
      items={[
        {
          year: '2014.08.01',
          title: '可琪创立理科迷',
          description:
            '可琪创建了第一个群聊——〔理科迷宅基地〕，后几经更名，如〔理科α旗舰〕等。他是理科迷最初的创始人，社区现有的大部分框架与制度，都建立在他开创的基础之上。',
          iconName: 'tabler:star',
        },
        {
          year: '2014',
          title: '腾讯部落与公众号上线',
          description:
            '腾讯部落平台上线后，可琪抢注多个部落，成功开设"物理部落"，持续更新科技新闻与科普内容，吸引大量科技爱好者关注。同期运营的微信公众号"腾讯物理部落"也同步发力，理科迷正式步入发展轨道。',
          iconName: 'tabler:brand-telegram',
        },
        {
          year: '2014 ~ 2016',
          title: '群组扩张，与百度贴吧建立联系',
          description:
            '理科迷群组进入快速扩张期，从百度物理吧、数学吧、化学吧等社区吸收大量成员，其中与物理吧的联系最为密切。群友涵盖理科生与竞赛生，早期管理员团队也由活跃群友中选拔组建。',
          iconName: 'tabler:users-plus',
        },
        {
          year: '2015 ~ 2016',
          title: '学科分群体系建立',
          description:
            '各学科分群陆续创立：数学（2015.12.22）、物理学、化学、生物学（2015.12.25），以及高中数学、物理、化学（2016.2.5），初中数学、生物（2016.2.4）。早期的学科分群体系初步成型。',
          iconName: 'tabler:folders',
        },
        {
          year: '2016',
          title: '兴趣群组持续扩展',
          description:
            '物理部落群（2016.4.2）、信息技术群（2016.2.5）、科技世界群（2016.2.15）、心理学群（2016.10.7）等兴趣群组相继建立，社群生态进一步丰富。',
          iconName: 'tabler:puzzle',
        },
        {
          year: '2017 ~ 2018',
          title: '网站规划与新闻社构想',
          description:
            '线上网站曾有过规划并短暂试运行，但未能正式搭建运营。同期设想的新闻社——用于发布科技资讯——也仅停留在纸面阶段，未最终落地。',
          iconName: 'tabler:file-text',
        },
        {
          year: '2018',
          title: '创始人淡出，花花接续坚守',
          description:
            '可琪因学业原因逐渐淡出，理科迷随之陷入低迷。现任团队组长花花接替创始人职责，每年自费维持理科迷的 SVIP 及物理部落的日常运营——彼时部落每周需完成 20 次管理操作，否则管理团队将受处罚。后来腾讯部落功能下架，所有帖子一夜间消失，公众号也随之停用。',
          iconName: 'tabler:shield-check',
        },
        {
          year: '2018.02',
          title: '七月团队早期架构建立',
          description:
            '七月团队·群务组（2018.2.19）与总务组（2018.2.21）相继成立，同期创办棋社、料理学、HIFI 等兴趣群。由可琪召集组建的早期管理团队，为后续的组织运转奠定了制度基础。',
          iconName: 'tabler:building-community',
        },
        {
          year: '2019.08.15',
          title: '千寻入群，短暂回暖',
          description: '千寻加入理科迷群聊，原本沉寂已久的群聊开始重现活力。',
          iconName: 'tabler:user-plus',
        },
        {
          year: '2020',
          title: '再度沉寂：千寻备战中考',
          description:
            '千寻因年龄尚小、需全力备战中考，2020 年后逐渐淡出，群聊再度归于沉寂。理科迷历经聚散，一群人数跌落至仅 800 人。',
          iconName: 'tabler:user-minus',
        },
        {
          year: '2024.04.19',
          title: '群管理的呼唤，重建之心萌芽',
          description:
            '群管理再次找到千寻，诉说群人数已不足 800、社区沉寂已久。千寻内心开始动摇，重建理科迷的念头悄然萌芽。',
          iconName: 'tabler:message-heart',
        },
        {
          year: '2024.07.30',
          title: '下定决心，启动重建计划',
          description:
            '千寻正式下定决心重建并发展理科迷，开始向此前组织团队成员阐述视频宣传计划，为后续宣传攻势做铺垫。',
          iconName: 'tabler:rocket',
        },
        {
          year: '2024.08.10',
          title: '官方宣传账号成立，首条视频走红',
          description: '理科迷官方宣传账号正式上线，首条视频获 7800+ 播放量，社区迅速恢复活跃，理科迷迎来新生。',
          iconName: 'tabler:brand-youtube',
        },
        {
          year: '2025.01.08',
          title: '官方群组重组',
          description:
            '重新组建理科迷官方群组，设立﹝理科迷·初中﹞与﹝理科迷·高中﹞两个分群，为不同学段的成员提供更精准的交流空间。',
          iconName: 'tabler:users-group',
        },
        {
          year: '2025.04',
          title: '团队组建与官网文档库建设',
          description:
            '开始吸纳组建新团队，重新建设官网文档库，具备文档存储与词条查阅功能，打造面向社区内部的实用型知识平台。',
          iconName: 'tabler:database',
        },
        {
          year: '2025.04.02',
          title: '七月团队·活动策划部 成立',
          description:
            '组建﹝七月团队·活动策划部﹞，启动首次暑假活动策划。理科迷从线上交流走向有组织的活动运营，翻开新的一页。',
          iconName: 'tabler:calendar-event',
        },
        {
          year: '2025.07 ~ 2025.08',
          title: '第一次暑假活动落地',
          description:
            '首次暑假活动雏形落地。虽在组织细节上仍存不足，人手亦有待扩充，但这是一次珍贵的尝试，为后续活动积累了宝贵经验。',
          iconName: 'tabler:sun',
        },
        {
          year: '2025.08.04',
          title: '网站遭删库，一切归零',
          description:
            '网站因意外被删库，所有数据丢失。这次事故让团队深刻认识到备份机制与运维规范的重要性，也成为后续重建的转折点。',
          iconColor: 'text-red-500',
          iconName: 'tabler:alert-triangle',
        },
        {
          year: '2026.06',
          title: '涅槃重生：官网重建与第二次暑假筹备',
          description:
            '汲取删库教训，以更稳健的架构重建官网与文件库。同期启动第二次暑假活动策划，理科迷以全新的姿态再度启程。',
          iconName: 'tabler:refresh',
        },
      ]}
    />
  </Section>

