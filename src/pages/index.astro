    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <Section title="发展历程" subtitle="物换星移，春秋代序" tagline="Timeline" id="timeline">
    <div class="flex justify-center"></div>
    <Timeline
      items={[
        {
          year: '1984',
          title: 'First Macintosh computer',
