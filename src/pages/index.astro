  <!-- FAQs Widget ******************* -->

  <FAQs
    title="常见问题"
    subtitle="以下整理了用户关于 LKM 官方网站的常见疑问，帮助您快速了解项目特性和使用方式。"
    tagline="常见问题"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: '理科迷是什么？',
        description:
          '理科迷是一个由普罗大众组成的科技爱好者社区，创立于 2014 年。我们打破专业门槛，让每一位热爱理性、崇尚科学的人都能在这里找到同频的伙伴，共同探索万物运转的奥秘。',
      },
      {
        title: '如何加入理科迷？',
        description:
          '你可以通过理科迷官方 QQ 群组加入我们。目前设有初中群和高中群两个分群，为不同学段的成员提供更精准的交流空间。具体群号请查看联系我们页面。',
      },
      {
        title: '理科迷有哪些活动？',
        description:
          '理科迷定期举办暑假活动、学科研讨会、科普内容创作等。七月团队·活动策划部负责统筹各项活动，欢迎关注官方宣传账号获取最新动态。',
      },
      {
        title: '如何参与社区建设？',
        description:
          '理科迷是一个共建共享的社区。你可以加入管理团队（总务部、群务部、新闻办等），也可以投稿科普文章、参与暑假活动策划，或是帮忙宣传推广。',
      },
      {
        title: '理科迷有网站或文档库吗？',
        description:
          '是的。理科迷拥有官方网站和文档库，支持文档存储与词条查阅功能。2026 年我们以更稳健的架构重建了官网，为你提供更好的在线体验。',
      },
      {
        title: '有问题或建议怎么联系？',
        description:
          '欢迎通过联系我们页面提交你的想法或问题。也可以直接在 QQ 群内向管理团队反馈，我们会认真对待每一条建议。',
      },
    ]}
