---
import Layout from '~/layouts/SidebarLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { teamTopTabs } from '~/navigation';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: '赞助与支持',
};

const sidebarLinks = [
  { text: '支持方式', href: getPermalink('/pricing#support') },
  { text: '常见问题', href: getPermalink('/pricing#faq') },
];
---

<Layout metadata={metadata} topTabs={teamTopTabs} sidebarLinks={sidebarLinks} currentPath={getPermalink('/pricing')}>
  <!-- Hero -->
  <HeroText
    tagline="赞助与支持"
    title="让科技传播走得更远"
    subtitle="理科迷是一个非营利的科技爱好者社区。每一位成员的支持，都是我们持续前行的动力。"
  />

  <!-- 支持方式 -->
  <Features3
    id="support"
    title="支持方式"
    subtitle="你的每一份力量，都能帮助理科迷变得更好。以下是你参与社区建设的几种方式。"
    columns={2}
    items={[
      {
        title: '加入社区',
        description:
          '最直接的方式就是加入理科迷官方 QQ 群组，关注官方账号、参与讨论、分享知识、上传文件。每一位活跃的成员都是社区最宝贵的财富。',
        icon: 'tabler:users-plus',
      },
      {
        title: '创作内容',
        description:
          '我们对于创作是有长期征集计划，帮助类、学科类、科普类，当下热点——无论是文稿、视频、或是其他形式，都是组织最需要的实质内容，你的创作能让更多人感受到科技的魅力，并受惠于社区共建共享的体系下，能得到最诚恳的建议。欢迎大家联系新闻办投稿。',
        icon: 'tabler:pencil',
      },
      {
        title: '参与管理',
        description:
          '加入七月管理团队（总务部、群务部、策划部等），参与社群日常运营和策划执行，让组织实现长期目标，让社区更加繁荣，为理科迷的发展贡献你的才能。',
        icon: 'tabler:building-community',
      },
      {
        title: '参与项目',
        description:
          '加入七月项目团队（教材编写组、科普产出组），参与具体的产出内容落实，让知识传播出去，打破壁垒以及信息差。为更多渴求学习的孩子，能够得到知识。',
        icon: 'tabler:clipboard-list',
      },
      {
        title: '联系合作',
        description:
          '如果你有任何的资源，并不吝啬于分享以及合作共赢，欢迎联系总务部，我们可以详谈合作相关事宜，一起把社区办得更好。',
        icon: 'tabler:handshake',
      },
      {
        title: '宣传推广',
        description:
          '将理科迷的官方账号、理念、活动、实质的优质内容等分享给你的朋友和同学们，让更多热爱科技的小伙伴们知道我们的存在，每一个分享都是一次传播。',
        icon: 'tabler:share',
      },
      {
        title: '技术支持',
        description:
          '如果你擅长网站开发、UI 设计、服务器运维等技术，欢迎加入技术委员会，帮助理科迷建设更好的线上平台。',
        icon: 'tabler:code',
      },
      {
        title: '提出建议',
        description:
          '对理科迷有任何想法或建议？我们非常愿意倾听。通过联系我们页面提交你的反馈，我们认真对待每一条意见。',
        icon: 'tabler:bulb',
      },
    ]}
    classes={{ container: 'max-w-4xl mx-auto' }}
  />

  <!-- FAQ -->
  <Features3
    id="faq"
    title="常见问题"
    subtitle="关于支持方式的一些常见疑问，也许能解答你的困惑。"
    columns={2}
    items={[
      {
        title: '理科迷是否需要付费？',
        description: '不需要。理科迷是一个非营利组织，所有服务和内容均免费向社区成员开放，不收取任何费用。但由于社区的扩大，对于社群人数上限、域名、服务器以及活动等支出也日渐增高，未来会探索更多有可能的，维持开销的举措。',
        icon: 'tabler:free-rights',
      },
      {
        title: '理科迷经费来源于哪里？',
        description: '目前来源于团队里面成员自掏腰包。但不是长久之计，我们未来会尝试开办募捐等形式，并持续运行自媒体，为了能够步入正向循环，维持自身运营。',
        icon: 'tabler:coin',
      },
      {
        title: '理科迷经费收入和支出透明吗？',
        description: '透明。理科迷所有的经费属于集体，不属于个人，每一次的收入和支出均会进行公示，并接受社区成员监督。未来开办募捐的形式时也会让募捐的社员，成立一个崭新的工作组，负责相关的事宜。',
        icon: 'tabler:chart-bar',
      },
      {
        title: '我可以同时参与多个部门吗？',
        description: '当然可以。我们鼓励成员跨部门协作。只要你有时间精力，欢迎在多个领域发挥你的才能，并且我们鼓励成员提升自己，掌握更多的技能，承担更好的职能工作。',
        icon: 'tabler:layout-grid',
      },
      {
        title: '我可以主动提出项目建设吗？',
        description: '完全可以。理科迷社区属于集体，大家共建共享，自己承担，自己建设相关事务，七月团队会帮助项目组建工作，和管理团队支持和帮助，我们也欢迎大家更多有创造力、有领导力、有执行能力的人加入，让想法落地，加入团队，帮助更多的人！',
        icon: 'tabler:rocket',
      },
      {
        title: '没有相关经验可以参与吗？',
        description: '完全可以。理科迷欢迎每一位学习和贡献、建设的伙伴，为了大家承担工作，能够快速上手，我们将制定工作手册。并且我们组织分组是按照现有能力情况下，进行分组，不会让贡献者承担自己目前做不到的事情。',
        icon: 'tabler:user-heart',
      },
      {
        title: '在七月团队，有完整的体系吗？',
        description: '是的。在七月团队中有明确的每一个不同部门和分组，我们有管理规范守则和组织成员公约，需要每一位进行遵守。并且职位，可以按照成员现有的发展进行灵活更换，随着组织壮大，未来会更加明确晋升体系，帮助大家有更好的成长。',
        icon: 'tabler:building',
      },
      {
        title: '如何查看我的贡献记录？',
        description: '目前社群的贡献记录主要通过与社群和网站进行展示，未来我们计划建设更完善的贡献追踪和显示系统，让每一位"理科迷"都有归属感和组织认同。',
        icon: 'tabler:history',
      },
    ]}
    classes={{ container: 'max-w-4xl mx-auto' }}
  />

  <!-- CallToAction -->
  <CallToAction
    title="准备好为理科迷贡献一份力量了？"
    subtitle="加入我们的社区，与志同道合的伙伴一起，让科技传播走得更远。"
    actions={[
      {
        variant: 'primary',
        text: '联系我们',
        href: getPermalink('/contact'),
      },
    ]}
  />
</Layout>
