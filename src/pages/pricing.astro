---
import Layout from '~/layouts/SidebarLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: '赞助与支持',
};

const topTabs = [
  { text: '管理团队', href: getPermalink('/team') },
  { text: '关于我们', href: getPermalink('/about') },
  { text: '服务', href: getPermalink('/services') },
  { text: '赞助与支持', href: getPermalink('/pricing') },
  { text: '联系我们', href: getPermalink('/contact') },
];

const sidebarLinks = [
  { text: '支持方式', href: getPermalink('/pricing#support') },
  { text: '常见问题', href: getPermalink('/pricing#faq') },
];
---

<Layout metadata={metadata} topTabs={topTabs} sidebarLinks={sidebarLinks} currentPath={getPermalink('/pricing')}>
  <!-- Hero -->
  <HeroText
    tagline="赞助与支持"
    title="支持理科迷，让科学传播走得更远"
    subtitle="理科迷是一个非营利的科技爱好者社区。每一位成员的支持，都是我们持续前行的动力。"
  />

  <!-- 支持方式 -->
  <Features3
    id="support"
    title="如何支持我们"
    subtitle="你的每一份力量，都能帮助理科迷变得更好。以下是你参与社区建设的几种方式。"
    columns={2}
    items={[
      {
        title: '加入社区',
        description:
          '最直接的方式就是加入理科迷官方 QQ 群组，参与讨论、分享知识。每一位活跃的成员都是社区最宝贵的财富。',
        icon: 'tabler:users-plus',
      },
      {
        title: '创作内容',
        description:
          '投稿科普文章、制作科普视频、翻译国外优质内容——你的创作能让更多人感受到科学的魅力。欢迎联系新闻办投稿。',
        icon: 'tabler:pencil',
      },
      {
        title: '参与管理',
        description:
          '加入七月团队（总务部、群务部、新闻办、技术委员会等），参与社区日常运营与活动策划，为理科迷的发展贡献你的才能。',
        icon: 'tabler:building-community',
      },
      {
        title: '宣传推广',
        description: '将理科迷的内容分享给你的朋友和同学，让更多热爱科学的伙伴知道我们的存在。每一个分享都是一次传播。',
        icon: 'tabler:share',
      },
      {
        title: '技术支持',
        description:
          '如果你擅长网站开发、UI 设计、服务器运维等技术，欢迎加入技术委员会，帮助理科迷建设更好的线上平台。',
        icon: 'tabler:code',
      },
      {
        title: '提出建议',
        description:
          '对理科迷有任何想法或建议？我们非常愿意倾听。通过联系我们页面提交你的反馈，我们认真对待每一条意见。',
        icon: 'tabler:bulb',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- FAQ -->
  <Features3
    id="faq"
    title="常见问题"
    subtitle="关于支持方式的一些常见疑问，也许能解答你的困惑。"
    columns={2}
    items={[
      {
        title: '理科迷是否需要付费？',
        description: '不需要。理科迷是一个非营利社区，所有服务和内容均免费向社区成员开放。',
        icon: 'tabler:free-rights',
      },
      {
        title: '我可以同时参与多个部门吗？',
        description: '当然可以。我们鼓励成员跨部门协作。只要你有时间精力，欢迎在多个领域发挥你的才能。',
        icon: 'tabler:layout-grid',
      },
      {
        title: '没有相关经验可以参与吗？',
        description: '完全可以。理科迷欢迎每一位愿意学习和贡献的伙伴。只要你有热情，团队伙伴会帮助你快速上手。',
        icon: 'tabler:user-heart',
      },
      {
        title: '如何查看我的贡献记录？',
        description: '目前社区的贡献记录主要通过群聊和网站展示。未来我们计划建立更完善的贡献追踪与展示系统。',
        icon: 'tabler:history',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- CallToAction -->
  <CallToAction
    title="准备好为理科迷贡献一份力量了？"
    subtitle="加入我们的社区，与志同道合的伙伴一起，让科学传播走得更远。"
    actions={[
      {
        variant: 'primary',
        text: '联系我们',
        href: getPermalink('/contact'),
      },
    ]}
  />
</Layout>
