---
import HeroText from '~/components/widgets/HeroText.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/SidebarLayout.astro';

import { teamTopTabs } from '~/navigation';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: '关于我们',
};

const sidebarLinks = [
  { text: '概览', href: getPermalink('/about') },
  { text: '社区理念', href: getPermalink('/about#values') },
  { text: '发展成就', href: getPermalink('/about#achievements') },
  { text: '联系我们', href: getPermalink('/about#support') },
];
---

<Layout metadata={metadata} topTabs={teamTopTabs} sidebarLinks={sidebarLinks} currentPath={getPermalink('/about')}>
  <!-- Hero -->
  <HeroText tagline="关于我们">
    <Fragment slot="title">
      由<span class="text-[#6C2AD8]">科技爱好者</span>组成的<br />
      <span class="text-accent">社区</span>
    </Fragment>

    <Fragment slot="subtitle">
      理科迷创立于 2014 年，是一个面向所有科学爱好者的开放社区。我们从最初的一个 QQ
      群聊起步，历经十余年发展，已成长为覆盖数学、物理、化学、生物、信息技术等多个学科的综合型科技社区。我们相信——科学不属于少数人，每一个对世界保持好奇的普通人，都能在这里找到属于自己的位置。
    </Fragment>
  </HeroText>

  <!-- 社区理念 -->
  <Steps2
    id="values"
    title="社区理念"
    subtitle="理科迷的初心从未改变：打破学科壁垒，让科学回归大众。"
    items={[
      {
        title: '大众化',
        description:
          '科学与技术都脱离了学术象牙塔的刻板与遥远，变成了每一位都能够去迸发，对于世界发问的好奇心。摆脱功利视角，让更多人迸发对于知识的渴望，感受到理工科的美。我们打破专业门槛，让每一位热爱理性，崇尚科技的"爱好者"，也都能在这里找到同频的伙伴，共探万物运转的奥秘。',
        icon: 'tabler:bulb',
      },
      {
        title: '共建共享',
        description:
          '理科迷是一个由社区成员共同建设、共同维护的平台。从学科分群到官方宣传，从暑假活动到官网文档库，每一项进展都离不开团队伙伴与社区成员的共同努力。',
        icon: 'tabler:users-group',
      },
      {
        title: '传承与创新',
        description:
          '从 2014 年可琪创立的第一天起，历经创始人淡出、腾讯部落关停、网站删库等多次波折，理科迷从未真正消失。每一次低谷之后，总有新的力量接过火炬，让社区以更新的姿态重生。',
        icon: 'tabler:flame',
      },
    ]}
  />

  <!-- 发展成就 -->
  <Steps2
    id="achievements"
    title="发展成就"
    subtitle="十余年风雨兼程，理科迷走过的每一步都值得铭记。"
    isReversed={true}
    callToAction={{
      text: '查看完整历程',
      href: getPermalink('/#timeline'),
    }}
    items={[
      {
        title: '十二年社区积淀',
        description:
          '自 2014 年创立至今，理科迷已走过十二年。从最初的一个群聊，发展为覆盖全学科的社群网络，累计服务数以万计的科技爱好者。',
        icon: 'tabler:calendar-time',
      },
      {
        title: '完整的学科分群体系',
        description:
          '已建立数学、物理、化学、生物、信息技术等核心学科分群，覆盖初中、高中、大学各学段，为不同阶段的科学爱好者提供精准的交流空间。',
        icon: 'tabler:category-2',
      },
      {
        title: '2026 年涅槃重生',
        description:
          '经历 2025 年网站删库事故后，团队汲取教训，以更稳健的架构重建官网与文件库。同期启动第二次暑假活动策划，理科迷以全新姿态再度启程。',
        icon: 'tabler:refresh',
      },
    ]}
  />

  <!-- 联系我们 -->
  <Steps2
    id="support"
    title="联系我们"
    subtitle="无论你是想加入社区、提出建议，还是寻求合作，都欢迎联系我们。"
    items={[
      {
        title: '加入社区',
        description: '理科迷欢迎每一位热爱科学的伙伴。你可以通过官方群组加入我们，与志同道合的人一起交流、学习、成长。',
        icon: 'tabler:user-plus',
      },
      {
        title: '合作与建议',
        description:
          '如果你对理科迷的发展有任何建议，或者希望与我们开展合作，欢迎通过联系我们页面提交你的想法，我们会认真对待每一条反馈。',
        icon: 'tabler:message-heart',
      },
    ]}
    callToAction={{
      text: '联系我们',
      href: getPermalink('/contact'),
    }}
  />
</Layout>
