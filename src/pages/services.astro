---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/SidebarLayout.astro';

import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: '服务',
};

const topTabs = [
  { text: '管理团队', href: getPermalink('/team') },
  { text: '关于我们', href: getPermalink('/about') },
  { text: '服务', href: getPermalink('/services') },
  { text: '定价', href: getPermalink('/pricing') },
  { text: '联系我们', href: getPermalink('/contact') },
];

const sidebarLinks = [
  { text: '科普内容', href: getPermalink('/services#content') },
  { text: '社区活动', href: getPermalink('/services#events') },
  { text: '知识平台', href: getPermalink('/services#platform') },
];
---

<Layout metadata={metadata} topTabs={topTabs} sidebarLinks={sidebarLinks} currentPath={getPermalink('/services')}>
  <!-- Hero -->
  <Hero
    tagline="服务"
    title="让科学回归每一个人"
    subtitle="理科迷提供多种形式的科学传播与社区服务，从科普内容创作到学科交流社群，我们致力于打破知识壁垒，让更多人感受到科学的魅力。"
    actions={[{ variant: 'primary', target: '_self', text: '加入我们', href: '/contact' }]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: '理科迷服务',
    }}
  />

  <!-- 科普内容 -->
  <Features2
    id="content"
    title="科普内容创作"
    subtitle="由团队成员和社区成员共创的高质量科普内容，覆盖多个学科领域。"
    columns={3}
    items={[
      {
        title: '科技新闻',
        description: '追踪全球科技前沿动态，用通俗易懂的语言解读最新科学发现与技术突破，让你第一时间掌握科技脉搏。',
        icon: 'tabler:news',
      },
      {
        title: '学科科普',
        description:
          '覆盖数学、物理、化学、生物、信息技术等核心学科，从基础概念到前沿理论，循序渐进带你进入科学的世界。',
        icon: 'tabler:atom',
      },
      {
        title: '视频科普',
        description: '通过B站等视频平台发布科普视频，以生动直观的方式呈现科学知识，让抽象的公式和理论变得眼见为实。',
        icon: 'tabler:video',
      },
      {
        title: '专题深度',
        description: '针对热门科学话题推出系列专题文章，深入浅出地剖析背后的科学原理，培养批判性思维和科学素养。',
        icon: 'tabler:file-text',
      },
      {
        title: '知识竞赛',
        description: '定期举办线上学科知识竞赛，寓教于乐，激发学习兴趣，在轻松的氛围中检验和巩固所学知识。',
        icon: 'tabler:trophy',
      },
      {
        title: '资源分享',
        description: '整理和分享优质学习资料、书籍推荐、在线课程等学习资源，帮助社区成员找到最适合自己的学习路径。',
        icon: 'tabler:books',
      },
    ]}
  />

  <!-- 社区活动 -->
  <Features2
    id="events"
    title="社区活动"
    subtitle="从线上研讨到暑假活动，理科迷为社区成员提供丰富多彩的互动体验。"
    columns={2}
    items={[
      {
        title: '暑假活动',
        description:
          '一年一度的暑假主题活动，由七月团队·活动策划部统筹组织。汇集线上讲座、学科研讨、趣味竞赛等多种形式，是社区每年最大的盛事。',
        icon: 'tabler:sun',
      },
      {
        title: '学科研讨会',
        description: '由专业委员会委员和各学科爱好者共同参与，定期举办专题研讨，针对特定科学话题展开深入讨论与交流。',
        icon: 'tabler:presentation',
      },
      {
        title: '社群交流',
        description: '设有初中群和高中群两个官方 QQ 群组，以及各学科分群，为不同学段的成员提供精准、高效的交流空间。',
        icon: 'tabler:messages',
      },
      {
        title: '宣传推广',
        description: '通过官方宣传账号在 B 站等平台持续输出，扩大社区影响力，吸引更多热爱科学的伙伴加入我们。',
        icon: 'tabler:brand-youtube',
      },
    ]}
  />

  <!-- 知识平台 -->
  <Features2
    id="platform"
    title="知识平台"
    subtitle="理科迷正在建设面向社区成员的知识管理平台，助力学习与协作。"
    columns={3}
    items={[
      {
        title: '官方网站',
        description: '理科迷的线上门户，集成社区介绍、团队展示、博客文章、文档资源等功能，是我们面向公众的第一窗口。',
        icon: 'tabler:world-www',
      },
      {
        title: '文档库',
        description:
          '支持文档存储与词条查阅功能的知识平台，社区成员可以在这里查找和贡献学科知识，共建共享属于理科迷的知识宝库。',
        icon: 'tabler:database',
      },
      {
        title: '博客系统',
        description: '支持 Markdown 和 MDX 格式的文章发布，分类与标签过滤、阅读时间估算、RSS 订阅等功能一应俱全。',
        icon: 'tabler:article',
      },
    ]}
  />

  <!-- CallToAction -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: '联系我们',
        href: '/contact',
      },
    ]}
    title="对理科迷感兴趣？"
    subtitle="无论你是想加入社区、投稿科普文章，还是提出合作建议，我们都非常欢迎。"
  />
</Layout>
