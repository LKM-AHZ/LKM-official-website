---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import DocListItem from '~/components/docs/DocListItem.astro';
import { getPermalink } from '~/utils/permalinks';

const allDocs = await getCollection('docs', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const docsByCategory = new Map<string, typeof allDocs>();
for (const doc of allDocs) {
  const cat = doc.data.category || '未分类';
  if (!docsByCategory.has(cat)) docsByCategory.set(cat, []);
  docsByCategory.get(cat)!.push(doc);
}

const metadata = {
  title: '文档库 —— 理科迷',
  description: '理科迷社区文档库，包含使用指南、常见问题和技术文档',
};
---

<Layout metadata={metadata}>
  <div class="max-w-3xl mx-auto px-4 py-12 md:py-20">
    <div class="mb-12">
      <h1 class="text-[28px] md:text-[40px] font-bold tracking-tight text-[#1d1d1f] dark:text-white mb-3">文档库</h1>
      <p class="text-[17px] text-[#7a7a7a] dark:text-[#cccccc]">理科迷社区文档，帮助你快速了解和使用社区的各项功能</p>
    </div>

    {
      Array.from(docsByCategory.entries()).map(([category, docs]) => (
        <section class="mb-10">
          <h2 class="text-[13px] font-semibold uppercase tracking-wider text-[#0066cc] dark:text-[#2997ff] mb-3 px-2">
            {category}
          </h2>
          <ul class="divide-y divide-gray-100 dark:divide-gray-800">
            {docs.map((doc) => (
              <DocListItem doc={doc} href={getPermalink(`/docs/${doc.id}`)} />
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</Layout>
