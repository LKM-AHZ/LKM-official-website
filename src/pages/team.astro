---
import Layout from '~/layouts/SidebarLayout.astro';
import Section from '~/components/widgets/Section.astro';

import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: '管理团队 —— 理科迷',
};

const topTabs = [
  { text: '管理团队', href: getPermalink('/team') },
  { text: 'About us', href: getPermalink('/about') },
  { text: 'Services', href: getPermalink('/services') },
  { text: 'Pricing', href: getPermalink('/pricing') },
  { text: 'Contact', href: getPermalink('/contact') },
];

const sidebarLinks = [
  { text: '创始人', href: getPermalink('/team#founder') },
  { text: '总务组', href: getPermalink('/team#management') },
  { text: '顾问组', href: getPermalink('/team#advisors') },
  { text: '群务组', href: getPermalink('/team#affairs') },
];

