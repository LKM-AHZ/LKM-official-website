---
import Layout from '~/layouts/SidebarLayout.astro';
import Section from '~/components/widgets/Section.astro';

import { getPermalink } from '~/utils/permalinks';

import 若有千寻 from '~/assets/images/member/若有千寻.jpg';
import 千寻 from '~/assets/images/member/千寻.jpg';
import 七月花 from '~/assets/images/member/七月花.jpg';
import 七月清汉 from '~/assets/images/member/七月清汉.jpg';
import 七月A from '~/assets/images/member/七月A.jpg';
import 七月有珠 from '~/assets/images/member/七月有珠.jpeg';
import 七月Lichlet from '~/assets/images/member/七月Lichlet.jpeg';
import 七月知更鸟 from '~/assets/images/member/七月知更鸟.jpeg';
import 七月阿鸿 from '~/assets/images/member/七月阿鸿.jpeg';
import 七月墨染 from '~/assets/images/member/七月墨染.png';
import 七月有枝 from '~/assets/images/member/七月有枝.jpeg';
import 七月止水 from '~/assets/images/member/七月止水.png';
import 七月爱畅依间 from '~/assets/images/member/七月爱畅依间.jpeg';
import 七月夏 from '~/assets/images/member/七月夏.jpeg';
import 七月清浅 from '~/assets/images/member/七月清浅.jpeg';
import 七月badragon from '~/assets/images/member/七月badragon.jpeg';
import 七月三七 from '~/assets/images/member/七月三七.jpeg';
import 七月MK from '~/assets/images/member/七月MK.png';
import 七月赤 from '~/assets/images/member/七月赤.jpeg';
import 七月草薙铃 from '~/assets/images/member/七月草薙铃.png';
import 七月一前 from '~/assets/images/member/七月一前.png';
import 七月星染 from '~/assets/images/member/七月星染.png';
import 七月吴理 from '~/assets/images/member/七月吴理.png';
import 七月upogg from '~/assets/images/member/七月upogg.jpeg';
import 七月大雄 from '~/assets/images/member/七月大雄.jpeg';
import 七月JoshuaXue from '~/assets/images/member/七月Joshua Xue.png';
import 七月 from '~/assets/images/member/七月.png';
import 七月Bcent from '~/assets/images/member/七月Bcent.jpeg';
import 七月阿泠 from '~/assets/images/member/七月阿泠.jpeg';
import 七月彼方 from '~/assets/images/member/七月彼方.jpeg';
import 七月胡冰阳 from '~/assets/images/member/七月胡冰阳.jpeg';
import 七月O from '~/assets/images/member/七月O.png';
import 七月汽水 from '~/assets/images/member/七月汽水.png';
import 七月星河 from '~/assets/images/member/七月星河.png';
import 七月tetrodotoxin from '~/assets/images/member/七月tetrodotoxin.jpeg';
import 七月狄离 from '~/assets/images/member/七月狄离.png';
import 七月文 from '~/assets/images/member/七月文.jpeg';

const metadata = {
  title: '管理团队 —— 理科迷',
};

const topTabs = [
  { text: '管理团队', href: getPermalink('/team') },
  { text: '关于我们', href: getPermalink('/about') },
  { text: '服务', href: getPermalink('/services') },
  { text: '定价', href: getPermalink('/pricing') },
  { text: '联系我们', href: getPermalink('/contact') },
];

const sidebarLinks = [
  { text: '创始人', href: getPermalink('/team#founder') },
  { text: '总务部', href: getPermalink('/team#general') },
  { text: '群务部', href: getPermalink('/team#affairs') },
  { text: '活动策划部', href: getPermalink('/team#events') },
  { text: '新闻办', href: getPermalink('/team#news') },
  { text: '顾问团', href: getPermalink('/team#advisors') },
  { text: '技术委员会', href: getPermalink('/team#tech') },
  { text: '教材项目组', href: getPermalink('/team#textbook') },
  { text: '专业委员会', href: getPermalink('/team#professional') },
  { text: '已离开成员', href: getPermalink('/team#alumni') },
];

// Helper func to render a name's first character avatar
const getAvatar = (name: string) => {
  const first = name.replace('七月', '').charAt(0) || name.charAt(0);
  return first;
};
---

<Layout metadata={metadata} topTabs={topTabs} sidebarLinks={sidebarLinks} currentPath={getPermalink('/team')}>
  <!-- 创始人 -->
  <Section title="创始人" subtitle="理科迷的起点，一切从这里开始" tagline="创始人" id="founder">
    <div class="max-w-2xl mx-auto">
      <div class="card bg-base-100 shadow-xl">
        <div class="card-body items-center text-center">
          <div class="avatar mb-4">
            <div class="w-24 h-24 rounded-full">
              <img src={若有千寻.src} alt="可琪" class="w-24 h-24 rounded-full object-cover" />
            </div>
          </div>
          <h2 class="card-title text-2xl">可琪（若有千寻）</h2>
          <span class="text-primary font-semibold">创始人</span>
          <p class="text-base-content/70 mt-3 leading-relaxed">
            2014年8月1日，可琪创立了最初群聊——〔理科迷宅基地〕。他是理科迷最初的创始者，群里现有很多现有事物和框架，都是在他所做的事情之上建立起来的。
          </p>
          <p class="text-base-content/70 leading-relaxed">
            可琪创立了腾讯"物理部落"和微信公众号，吸引了大量科技爱好者；组建了最初的理科迷分群体系和七月团队管理架构。2018年因学业原因逐渐淡出，但理科迷的一切，都源于他的开创。
          </p>
          <div class="mt-4 text-sm text-base-content/50 italic">
            「可琪现在不在，但他确确实实是理科迷最初的创始者。」
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- 七月团队 · 总务部 -->
  <Section id="general">
    <div class="max-w-5xl mx-auto">
      <h3 class="text-xl font-bold mb-6 text-center">
        <span class="border-b-2 border-primary pb-1">七月团队 · 总务部</span>
      </h3>
      <p
        class="max-w-3xl mx-auto mb-6 px-6 py-4 bg-base-200/60 rounded-box text-center text-sm text-base-content/70 leading-relaxed"
      >
        该团队部门职责是统筹和规划相关事宜，引领团队能够互相协作，落实我们共同的宗旨和目标。总务部更适合有多线程处理能力以及执行能力的成员，会有跨部门的需要。
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- 七月花 -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月花.src} alt="七月花" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月花</h4>
            <p class="text-xs text-base-content/60 mt-2">一个有理想的PHD</p>
            <p class="text-xs text-info/70 mt-1 italic">"梦想：每个孩子都能接触科学"</p>
          </div>
        </div>
        <!-- 七月知更鸟 -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月知更鸟.src} alt="七月知更鸟" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月知更鸟</h4>
            <p class="text-xs text-base-content/60 mt-2">待填写，这位还是学生在沉淀当中（让我们期待他的成长吧～</p>
          </div>
        </div>
        <!-- 七月阿鸿 -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月阿鸿.src} alt="七月阿鸿" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月阿鸿</h4>
          </div>
        </div>
        <!-- 七月墨染 -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月墨染.src} alt="七月墨染" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月墨染</h4>
            <p class="text-xs text-base-content/60 mt-2">双非物理，目前正跑路中</p>
            <p class="text-xs text-info/70 mt-1 italic">"梦想：我必将大雪深埋"</p>
            <p class="text-xs text-accent/70 mt-1">—— 卧薪尝胆三千日，大雪深埋终成金</p>
          </div>
        </div>
        <!-- 七月有枝 -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月有枝.src} alt="七月有枝" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月有枝</h4>
            <p class="text-xs text-base-content/60 mt-2">小黑猫，前活动策划组组员，初中研讨会执行员</p>
            <p class="text-xs text-info/70 mt-1 italic">"梦想：吃好喝好睡好玩好"</p>
            <p class="text-xs text-accent/70 mt-1">—— 且停且忘且随风，且行且看且从容</p>
          </div>
        </div>
        <!-- 七月千寻 -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={千寻.src} alt="千寻" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月千寻</h4>
            <span class="text-base-content/60 text-sm">活动策划部部长</span>
            <p class="text-xs text-base-content/60 mt-2">
              19年初二时加入理科迷，现在我是一个待打工人。无论是过去的哥哥姐姐们，还是现在比我小的弟弟妹妹们，我都不希望我的遗憾能够出现在他们身上，也希望在未来更多的人能够喜欢理工科。
            </p>
            <p class="text-xs text-info/70 mt-1 italic">
              "梦想：让理科迷能够做大做强，践行宗旨。最眼前的还是要实行短期目标，建设一个成熟完整的线上管理团队。"
            </p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- 七月团队 · 群务部 -->
  <Section id="affairs">
    <div class="max-w-5xl mx-auto">
      <h3 class="text-xl font-bold mb-6 text-center">
        <span class="border-b-2 border-accent pb-1">七月团队 · 群务部</span>
      </h3>
      <p
        class="max-w-3xl mx-auto mb-6 px-6 py-4 bg-base-200/60 rounded-box text-center text-sm text-base-content/70 leading-relaxed"
      >
        该团队部门职责是负责各个平台上面社群秩序，把握群内风向，确保群处于活跃并且持续有效的学习讨论氛围当中，有情况的时候第一时间处理。群务部更适合有常驻某一平台社群的成员，并具备一定的应急处理能力。
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- 七月止水 -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月止水.src} alt="七月止水" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月止水</h4>
            <p class="text-xs text-base-content/60 mt-2">努力学习中～</p>
          </div>
        </div>
        <!-- 七月清汉 -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月清汉.src} alt="七月清汉" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月清汉</h4>
            <p class="text-xs text-base-content/60 mt-2">保密awa</p>
            <p class="text-xs text-info/70 mt-1 italic">"梦想：无义务告知"</p>
            <p class="text-xs text-accent/70 mt-1">—— WELCOME TO OUR KINGDOM ！</p>
          </div>
        </div>
        <!-- 七月爱畅依间 -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月爱畅依间.src} alt="七月爱畅依间" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月爱畅依间</h4>
          </div>
        </div>
        <!-- 七月夏 -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月夏.src} alt="七月夏" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月夏</h4>
            <p class="text-xs text-base-content/60 mt-2">是一只小夏</p>
            <p class="text-xs text-info/70 mt-1 italic">"梦想：成为一本百科全书"</p>
            <p class="text-xs text-accent/70 mt-1">—— 敬不完美的明天</p>
          </div>
        </div>
        <!-- 七月清浅 -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月清浅.src} alt="七月清浅" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月清浅</h4>
            <p class="text-xs text-base-content/60 mt-2">略微潜水人，知识储量不丰富（</p>
            <p class="text-xs text-info/70 mt-1 italic">"梦想：成为一名科研工作者"</p>
          </div>
        </div>
        <!-- 七月badragon （初中） -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月badragon.src} alt="七月badragon" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月badragon</h4>
            <span class="text-base-content/60 text-sm">初中</span>
            <p class="text-xs text-base-content/60 mt-2">关注理科迷谢谢喵</p>
          </div>
        </div>
        <!-- 七月三七 （初中） -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月三七.src} alt="七月三七" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月三七</h4>
            <span class="text-base-content/60 text-sm">初中</span>
          </div>
        </div>
        <!-- 七月MK -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月MK.src} alt="七月MK" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月MK</h4>
            <p class="text-xs text-base-content/60 mt-2">
              10后，叫我MK就行。正在学习日语，喜欢数学（不是大佬喵）。最喜欢的动漫角色是《魔女之旅》的伊蕾娜。B站UID:1929696645
            </p>
            <p class="text-xs text-info/70 mt-1 italic">"梦想：拥有百万粉丝的UP"</p>
            <p class="text-xs text-accent/70 mt-1">—— 你应当……ネバー•ギブ•アップ！</p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- 七月团队 · 活动策划部 -->
  <Section id="events">
    <div class="max-w-5xl mx-auto">
      <h3 class="text-xl font-bold mb-6 text-center">
        <span class="border-b-2 border-warning pb-1">七月团队 · 活动策划部</span>
      </h3>
      <p
        class="max-w-3xl mx-auto mb-6 px-6 py-4 bg-base-200/60 rounded-box text-center text-sm text-base-content/70 leading-relaxed"
      >
        该团队负责的是各个平台上面的活动，一条龙从策划开始一直到执行，下管专业委员会，给大家带来更多更好的活动和体验，让大家能够真正的学到知识。适合有灵感、有创意并有能把这些全部落实的行动力加入。
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- 千寻 (部长) -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={千寻.src} alt="千寻" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">千寻</h4>
            <span class="text-base-content/60 text-sm">部长</span>
          </div>
        </div>
        <!-- 七月赤 （常驻） -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月赤.src} alt="七月赤" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月赤</h4>
            <span class="text-base-content/60 text-sm">常驻</span>
            <p class="text-xs text-base-content/60 mt-2">辽宁省某省重点高中毕业，26年报考目标东北地区985高校</p>
            <p class="text-xs text-info/70 mt-1 italic">"梦想：做一名大国工匠"</p>
            <p class="text-xs text-accent/70 mt-1">—— 干惊天动地事，做隐姓埋名人</p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- 新闻办 -->
  <Section id="news">
    <div class="max-w-5xl mx-auto">
      <h3 class="text-xl font-bold mb-6 text-center">
        <span class="border-b-2 border-info pb-1">新闻办</span>
      </h3>
      <p
        class="max-w-3xl mx-auto mb-6 px-6 py-4 bg-base-200/60 rounded-box text-center text-sm text-base-content/70 leading-relaxed"
      >
        该团队部门职责是负责各平台宣传账号的持续运营以及外交事宜，持续宣传输出并扩大影响能力，并为此向大众输出科普内容，促进传播知识。新闻办下属科普项目组及翻译项目组，为科普事业繁荣昌盛，以及中外科技爱好者能有所知识共享，破除信息差和壁垒。
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- 七月草薙铃 -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body items-center text-center p-5">
            <div class="avatar mb-3">
              <div class="w-16 h-16 rounded-full">
                <img src={七月草薙铃.src} alt="七月草薙铃" class="w-16 h-16 rounded-full object-cover" />
              </div>
            </div>
            <h4 class="font-bold text-lg">七月草薙铃</h4>
            <p class="text-xs text-base-content/60 mt-2">一个不存在,但是希望祝福大家的人.</p>
            <p class="text-xs text-info/70 mt-1 italic">"梦想：让大家开心,到达知识的Sekai边缘."</p>
