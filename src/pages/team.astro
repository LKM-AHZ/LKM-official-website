---
import Layout from '~/layouts/SidebarLayout.astro';
import Section from '~/components/widgets/Section.astro';
import MemberCard from '~/components/MemberCard.astro';
import DepartmentSection from '~/components/DepartmentSection.astro';

import type { ImageMetadata } from 'astro';

import {
  founderMembers,
  generalMembers,
  affairsMembers,
  eventsMembers,
  newsMembers,
  newsSubGroups,
  advisorMembers,
  techMembers,
  professionalSubGroups,
  projectMembers,
  alumniMembers,
} from '~/data/members';

import { teamTopTabs } from '~/navigation';
import { getPermalink } from '~/utils/permalinks';

// --- 图片映射：avatarKey → ImageMetadata ---
// 用到的图片文件名：
import img_若有千寻 from '~/assets/images/member/若有千寻.jpg';
import img_千寻 from '~/assets/images/member/千寻.jpg';
import img_七月花 from '~/assets/images/member/七月花.jpg';
import img_七月A from '~/assets/images/member/七月A.jpg';
import img_七月有珠 from '~/assets/images/member/七月有珠.jpeg';
import img_七月Lichlet from '~/assets/images/member/七月Lichlet.jpeg';
import img_七月知更鸟 from '~/assets/images/member/七月知更鸟.jpeg';
import img_七月阿鸿 from '~/assets/images/member/七月阿鸿.jpeg';
import img_七月墨染 from '~/assets/images/member/七月墨染.png';
import img_七月有枝 from '~/assets/images/member/七月有枝.jpeg';
import img_七月komoyume from '~/assets/images/member/七月komoyume.jpeg';
import img_七月止水 from '~/assets/images/member/七月止水.png';
import img_七月清汉 from '~/assets/images/member/七月清汉.jpg';
import img_七月爱畅依间 from '~/assets/images/member/七月爱畅依间.jpeg';
import img_七月夏 from '~/assets/images/member/七月夏.jpeg';
import img_七月清浅 from '~/assets/images/member/七月清浅.jpeg';
import img_七月badragon from '~/assets/images/member/七月badragon.jpeg';
import img_七月三七 from '~/assets/images/member/七月三七.jpeg';
import img_七月MK from '~/assets/images/member/七月MK.png';
import img_七月赤 from '~/assets/images/member/七月赤.jpeg';
import img_七月草薙铃 from '~/assets/images/member/七月草薙铃.png';
import img_七月一前 from '~/assets/images/member/七月一前.png';
import img_七月星染 from '~/assets/images/member/七月星染.png';
import img_七月吴理 from '~/assets/images/member/七月吴理.png';
import img_七月upogg from '~/assets/images/member/七月upogg.jpeg';
import img_七月大雄 from '~/assets/images/member/七月大雄.jpeg';
import img_七月JoshuaXue from '~/assets/images/member/七月Joshua Xue.png';
import img_七月 from '~/assets/images/member/七月.png';
import img_七月Bcent from '~/assets/images/member/七月Bcent.jpeg';
import img_七月阿泠 from '~/assets/images/member/七月阿泠.jpeg';
import img_七月彼方 from '~/assets/images/member/七月彼方.jpeg';
import img_七月胡冰阳 from '~/assets/images/member/七月胡冰阳.jpeg';
import img_七月O from '~/assets/images/member/七月O.png';
import img_七月汽水 from '~/assets/images/member/七月汽水.png';
import img_七月星河 from '~/assets/images/member/七月星河.png';
import img_七月tetrodotoxin from '~/assets/images/member/七月tetrodotoxin.jpeg';
import img_七月狄离 from '~/assets/images/member/七月狄离.png';
import img_七月文 from '~/assets/images/member/七月文.jpeg';

const avatarMap: Record<string, ImageMetadata> = {
  '若有千寻.jpg': img_若有千寻,
  '千寻.jpg': img_千寻,
  '七月花.jpg': img_七月花,
  '七月A.jpg': img_七月A,
  '七月有珠.jpeg': img_七月有珠,
  '七月Lichlet.jpeg': img_七月Lichlet,
  '七月知更鸟.jpeg': img_七月知更鸟,
  '七月阿鸿.jpeg': img_七月阿鸿,
  '七月墨染.png': img_七月墨染,
  '七月有枝.jpeg': img_七月有枝,
  '七月komoyume.jpeg': img_七月komoyume,
  '七月止水.png': img_七月止水,
  '七月清汉.jpg': img_七月清汉,
  '七月爱畅依间.jpeg': img_七月爱畅依间,
  '七月夏.jpeg': img_七月夏,
  '七月清浅.jpeg': img_七月清浅,
  '七月badragon.jpeg': img_七月badragon,
  '七月三七.jpeg': img_七月三七,
  '七月MK.png': img_七月MK,
  '七月赤.jpeg': img_七月赤,
  '七月草薙铃.png': img_七月草薙铃,
  '七月一前.png': img_七月一前,
  '七月星染.png': img_七月星染,
  '七月吴理.png': img_七月吴理,
  '七月upogg.jpeg': img_七月upogg,
  '七月大雄.jpeg': img_七月大雄,
  '七月Joshua Xue.png': img_七月JoshuaXue,
  '七月.png': img_七月,
  '七月Bcent.jpeg': img_七月Bcent,
  '七月阿泠.jpeg': img_七月阿泠,
  '七月彼方.jpeg': img_七月彼方,
  '七月胡冰阳.jpeg': img_七月胡冰阳,
  '七月O.png': img_七月O,
  '七月汽水.png': img_七月汽水,
  '七月星河.png': img_七月星河,
  '七月tetrodotoxin.jpeg': img_七月tetrodotoxin,
  '七月狄离.png': img_七月狄离,
  '七月文.jpeg': img_七月文,
};

function getAvatar(key?: string): ImageMetadata | undefined {
  if (!key) return undefined;
  return avatarMap[key];
}

const metadata = {
  title: '管理团队 —— 理科迷',
};

const sidebarLinks = [
  { text: '创始人', href: getPermalink('/team#founder') },
  { text: '总务部', href: getPermalink('/team#general') },
  { text: '群务部', href: getPermalink('/team#affairs') },
  { text: '活动策划部', href: getPermalink('/team#events') },
  { text: '新闻办', href: getPermalink('/team#news') },
  { text: '顾问团', href: getPermalink('/team#advisors') },
  { text: '技术委员会', href: getPermalink('/team#tech') },
  { text: '专业委员会', href: getPermalink('/team#professional') },
  { text: '已离开成员', href: getPermalink('/team#alumni') },
];
---

<Layout metadata={metadata} topTabs={teamTopTabs} sidebarLinks={sidebarLinks} currentPath={getPermalink('/team')}>
  <!-- 创始人 -->
  <Section title="创始人" subtitle="理科迷的起点，一切从这里开始" tagline="创始人" id="founder">
    <div class="max-w-2xl mx-auto">
      {
        founderMembers.map((m) => (
          <MemberCard
            name={m.name}
            avatar={getAvatar(m.avatarKey)}
            role={m.role}
            size="lg"
            desc={m.desc}
            dream={m.dream}
            quote={m.quote}
          />
        ))
      }
    </div>
  </Section>

  <!-- 总务部 -->
  <DepartmentSection
    id="general"
    title="七月团队 · 总务部"
    borderColor="var(--color-primary)"
    desc="该团队部门职责是统筹和规划相关事宜，引领团队能够互相协作，落实我们共同的宗旨和目标。总务部更适合有多线程处理能力以及执行能力的成员，会有跨部门的需要。"
  >
    {
      generalMembers.map((m) => (
        <MemberCard name={m.name} avatar={getAvatar(m.avatarKey)} desc={m.desc} dream={m.dream} quote={m.quote} />
      ))
    }
  </DepartmentSection>

  <!-- 群务部 -->
  <DepartmentSection
    id="affairs"
    title="七月团队 · 群务部"
    borderColor="var(--color-primary)"
    desc="该团队部门职责是负责各个平台上面社群秩序，把握群内风向，确保群处于活跃并且持续有效的学习讨论氛围当中，有情况的时候第一时间处理。群务部更适合有常驻某一平台社群的，并有一定的应急处理能力。"
  >
    {
      affairsMembers.map((m) => (
        <MemberCard
          name={m.name}
          avatar={getAvatar(m.avatarKey)}
          role={m.role}
          desc={m.desc}
          dream={m.dream}
          quote={m.quote}
        />
      ))
    }
  </DepartmentSection>

  <!-- 活动策划部 -->
  <DepartmentSection
    id="events"
    title="七月团队 · 活动策划部"
    borderColor="var(--color-warning)"
    desc="该团队负责的是各个平台上面的活动，一条龙从策划开始，一直到执行，下管专业委员会，给大家带来更多更好的活动和体验，让大家能够真正的学到知识。适合有灵感、有创意并由能把这些全部落实的行动力加入。"
  >
    {
      eventsMembers.map((m) => (
        <MemberCard
          name={m.name}
          avatar={getAvatar(m.avatarKey)}
          role={m.role}
          desc={m.desc}
          dream={m.dream}
          quote={m.quote}
        />
      ))
    }
  </DepartmentSection>

  <!-- 新闻办 -->
  <DepartmentSection
    id="news"
    title="新闻办"
    borderColor="var(--color-info)"
    desc="该团队部门职责是负责各平台宣传账号的持续运营，以及外交事宜，持续宣传输出并扩大影响能力，并为此向大众输出科普内容，促进传播知识。新闻办会下属一个科普项目组，以及翻译项目组，为科普事业繁荣昌盛，以及中外科技爱好者能有所知识共享，破除信息差和壁垒。"
    noGrid
  >
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        newsMembers.map((m) => (
          <MemberCard name={m.name} avatar={getAvatar(m.avatarKey)} desc={m.desc} dream={m.dream} quote={m.quote} />
        ))
      }
    </div>
    {
      Object.entries(newsSubGroups).map(([, group]) => (
        <div class="mt-8">
          <h4 class="text-md font-bold mb-2 text-center text-neutral">{group.label}</h4>
          <p class="max-w-3xl mx-auto mb-4 px-6 py-3 bg-base-200 border border-base-300 rounded-[8px] text-center text-[13px] text-neutral leading-relaxed">
            {group.desc}
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {group.members.map((m) => (
              <MemberCard name={m.name} avatar={getAvatar(m.avatarKey)} desc={m.desc} dream={m.dream} quote={m.quote} />
            ))}
          </div>
        </div>
      ))
    }
  </DepartmentSection>

  <!-- 顾问团 -->
  <DepartmentSection
    id="advisors"
    title="顾问团"
    borderColor="var(--color-neutral)"
    desc="该团队部门职责是属于理科迷的外部顾问，为理科迷的工作组，项目组事业提供相应的支持，如法律询问、其他社会组织团体等等。"
  >
    {
      advisorMembers.map((m) => (
        <MemberCard name={m.name} avatar={getAvatar(m.avatarKey)} role={m.role} desc={m.desc} dream={m.dream} quote={m.quote} />
      ))
    }
  </DepartmentSection>

  <!-- 专业委员会 -->
  <DepartmentSection
    id="professional"
    title="专业委员会"
    borderColor="var(--color-success)"
    desc="该团队部门职责是负责活动、项目等诸多提供专业知识，充实各个专业实际内容。成员是已经确定了想要在这方面深耕的，未来会下管学术项目组，带来更好的学术交流等内容。"
    noGrid
  >
    {
      Object.entries(professionalSubGroups).map(([, group]) => (
        <div class="mb-8">
          <h4 class="text-md font-bold mb-2 text-center text-neutral">{group.label}</h4>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {group.members.map((m) => (
              <MemberCard name={m.name} avatar={getAvatar(m.avatarKey)} desc={m.desc} dream={m.dream} quote={m.quote} />
            ))}
          </div>
        </div>
      ))
    }
  </DepartmentSection>

  <!-- 技术委员会 -->
  <DepartmentSection
    id="tech"
    title="技术委员会"
    borderColor="var(--color-error)"
    desc="该团队部门职责是负责各平台、各活动的相应技术上的技术开发与维护，未来将给大家带来更多实用性更强更好的开源项目。需要有编程知识，网站搭建等能。"
  >
    {
      techMembers.map((m) => (
        <MemberCard name={m.name} avatar={getAvatar(m.avatarKey)} role={m.role} desc={m.desc} dream={m.dream} quote={m.quote} />
      ))
    }
  </DepartmentSection>

  <!-- 项目团队成员 -->
  <Section id="project">
    <div class="max-w-7xl mx-auto">
      <h3 class="text-xl font-bold mb-6 text-center">
        <span class="border-b-2 border-base-300 pb-1">项目团队成员</span>
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          projectMembers.map((m) => (
            <MemberCard name={m.name} avatar={getAvatar(m.avatarKey)} desc={m.desc} dream={m.dream} quote={m.quote} />
          ))
        }
      </div>
    </div>
  </Section>

  <!-- 已离开成员 -->
  <Section id="alumni">
    <div class="max-w-7xl mx-auto">
      <h3 class="text-xl font-bold mb-6 text-center">
        <span class="border-b-2 border-base-300 pb-1">已离开或失联成员</span>
      </h3>
      <p
        class="max-w-3xl mx-auto mb-6 px-6 py-4 bg-base-200 border border-base-300 rounded-[8px] text-center text-[14px] text-neutral leading-relaxed"
      >
        以下成员曾为理科迷作出贡献，因各种原因现无法联系，不管如何理科迷的大门永远向你们打开。
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {alumniMembers.map((m) => <MemberCard name={m.name} avatar={getAvatar(m.avatarKey)} role={m.role} desc={m.desc} dream={m.dream} quote={m.quote} />)}
      </div>
    </div>
  </Section>
</Layout>
