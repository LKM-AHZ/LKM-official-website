---
import { Icon } from 'astro-icon/components';
import styles from './Sidebar.module.css';

interface SidebarLink {
  text: string;
  href: string;
  icon?: string;
}

export interface Props {
  links?: SidebarLink[];
  currentPath?: string;
}

const { links = [], currentPath = '' } = Astro.props;
---

<nav class={styles.nav} aria-label="Sidebar navigation" data-sidebar>
  {
    links.length > 0 && (
      <ul class={styles.linkList}>
        {links.map(({ text, href, icon }) => {
          const isActive = (() => {
            const linkUrl = new URL(href, 'https://example.com');
            if (linkUrl.hash) return currentPath === href;
            return currentPath === href || currentPath.startsWith(href + '#');
          })();
          return (
            <li>
              <a
                href={href}
                class:list={[
                  styles.link,
                  isActive
                    ? 'bg-primary/10 text-primary font-semibold'
                    : [styles.linkInactive, 'text-neutral hover:text-base-content'],
                ]}
              >
                {icon && <Icon name={icon} class={styles.icon} />}
                <span>{text}</span>
              </a>
            </li>
          );
        })}
      </ul>
    )
  }
</nav>

<script>
  function initSidebarScroll() {
    const sidebar = document.querySelector('[data-sidebar]');
    if (!sidebar) return;

    const links = sidebar.querySelectorAll('a[href]');

    // 点击平滑滚动
    const handler = (e: Event) => {
      const link = (e.target as HTMLElement).closest('a[href]');
      if (!link) return;

      const href = link.getAttribute('href');
      if (!href) return;

      const url = new URL(href, location.origin);
      const isSamePage = url.pathname.replace(/\/$/, '') === location.pathname.replace(/\/$/, '');
      const hash = url.hash;

      if (!hash || !isSamePage) return;

      e.preventDefault();
      const target = document.querySelector(hash);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
        history.replaceState(null, '', hash);
        updateActive();
      }
    };

    // 根据当前滚动位置/URL hash 更新高亮
    function updateActive() {
      const currentHash = location.hash;
      links.forEach((a) => {
        const href = a.getAttribute('href');
        if (!href) return;
        const linkUrl = new URL(href, location.origin);
        // 标准化比较 pathname（去掉末尾 /）
        if (linkUrl.pathname.replace(/\/$/, '') !== location.pathname.replace(/\/$/, '')) return;

        const isActive = linkUrl.hash ? linkUrl.hash === currentHash : !currentHash;
        if (isActive) {
          a.classList.add('bg-primary/10', 'text-primary', 'font-semibold');
          a.classList.remove('text-neutral', 'hover:text-base-content');
        } else {
          a.classList.remove('bg-primary/10', 'text-primary', 'font-semibold');
          a.classList.add('text-neutral', 'hover:text-base-content');
        }
      });
    }

    // 滚动监听
    let scrollTicking = false;
    function onScroll() {
      if (!scrollTicking) {
        requestAnimationFrame(() => {
          const sections = [...links]
            .map((a) => {
              const href = a.getAttribute('href');
              if (!href) return null;
              const url = new URL(href, location.origin);
              if (url.pathname.replace(/\/$/, '') !== location.pathname.replace(/\/$/, '') || !url.hash) return null;
              return document.querySelector(url.hash);
            })
            .filter(Boolean) as HTMLElement[];

          if (sections.length === 0) return;

          // 找到最接近视口顶部且已滚过的 section
          let currentId = '';
          for (const section of sections) {
            const rect = section.getBoundingClientRect();
            if (rect.top <= 120) {
              currentId = '#' + section.id;
              // 不 break，取最后一个满足条件的（最靠下的可见 section）
            }
          }
          if (currentId && location.hash !== currentId) {
            history.replaceState(null, '', currentId);
            updateActive();
          } else if (!currentId && location.hash) {
            // 滚动到顶部附近，清除 hash
            history.replaceState(null, '', location.pathname);
            updateActive();
          }
          scrollTicking = false;
        });
        scrollTicking = true;
      }
    }

    // Remove previous handler before re-attaching (prevents duplicates on astro:after-swap)
    const sidebarWithHandler = sidebar as HTMLElement & {
      _sidebarHandler?: EventListener;
      _scrollHandler?: EventListener;
    };
    const prevHandler = sidebarWithHandler._sidebarHandler;
    const prevScroll = sidebarWithHandler._scrollHandler;
    if (prevHandler) sidebar.removeEventListener('click', prevHandler);
    if (prevScroll) window.removeEventListener('scroll', prevScroll);
    sidebar.addEventListener('click', handler);
    sidebarWithHandler._sidebarHandler = handler as EventListener;
    window.addEventListener('scroll', onScroll, { passive: true });
    sidebarWithHandler._scrollHandler = onScroll as EventListener;

    updateActive();
  }

  initSidebarScroll();
  document.addEventListener('astro:after-swap', initSidebarScroll);
</script>
