---
import { Icon } from 'astro-icon/components';
import styles from './Sidebar.module.css';

interface SidebarGroup {
  text: string;
  href: string;
  icon: string;
}

interface SidebarLogo {
  src: string;
  text: string;
  href: string;
}

interface Props {
  logo?: SidebarLogo;
  groups?: SidebarGroup[];
  currentPath?: string;
}

const { logo, groups = [], currentPath = '' } = Astro.props;
---

<nav class={styles.shell} aria-label="Sidebar navigation" data-sidebar>
  <ul class={styles.nav}>
    {
      logo && (
        <li class:list={[styles.logoItem, { active: currentPath === logo.href }]}>
          <a href={logo.href}>
            <div class={styles.icon}>
              <div class={styles.imageBox}>
                <img src={logo.src} alt={logo.text} />
              </div>
            </div>
            <div class={styles.text}>{logo.text}</div>
          </a>
        </li>
      )
    }

    {
      groups.map(({ text, href, icon }) => {
        const isActive = (() => {
          const linkUrl = new URL(href, 'https://example.com');
          if (linkUrl.hash) return currentPath === href;
          return currentPath === href || currentPath.startsWith(href + '#');
        })();

        return (
          <li class:list={{ active: isActive }}>
            <a href={href}>
              <div class={styles.icon}>
                <Icon name={icon} />
              </div>
              <div class={styles.text}>{text}</div>
            </a>
          </li>
        );
      })
    }
  </ul>

  <button class={styles.toggle} aria-label="Toggle sidebar" id="sidebar-toggle-btn">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"><path d="M9 18l6-6-6-6"></path></svg
    >
    <span class={styles.toggleText}>收起</span>
  </button>
</nav>

<script>
  function initSidebarScroll() {
    const sidebar = document.querySelector('[data-sidebar]');
    if (!sidebar) return;

    const links = sidebar.querySelectorAll('a[href]');

    const handler = (e: Event) => {
      const link = (e.target as HTMLElement).closest('a[href]');
      if (!link) return;

      const href = link.getAttribute('href');
      if (!href) return;

      const url = new URL(href, location.origin);
      const isSamePage = url.pathname.replace(/\/$/, '') === location.pathname.replace(/\/$/, '');
      const hash = url.hash;

      if (!hash || !isSamePage) return;

      e.preventDefault();
      const target = document.querySelector(hash);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
        history.replaceState(null, '', hash);
        updateActive();
      }
    };

    function updateActive() {
      const currentHash = location.hash;
      links.forEach((a) => {
        const href = a.getAttribute('href');
        if (!href) return;
        const linkUrl = new URL(href, location.origin);
        if (linkUrl.pathname.replace(/\/$/, '') !== location.pathname.replace(/\/$/, '')) return;

        const li = a.closest('li');
        if (!li) return;

        const isActive = linkUrl.hash ? linkUrl.hash === currentHash : !currentHash;
        if (isActive) {
          li.classList.add('active');
        } else {
          li.classList.remove('active');
        }
      });
    }

    let scrollTicking = false;
    function onScroll() {
      if (!scrollTicking) {
        requestAnimationFrame(() => {
          const sections = [...links]
            .map((a) => {
              const href = a.getAttribute('href');
              if (!href) return null;
              const url = new URL(href, location.origin);
              if (url.pathname.replace(/\/$/, '') !== location.pathname.replace(/\/$/, '') || !url.hash) return null;
              return document.querySelector(url.hash);
            })
            .filter(Boolean) as HTMLElement[];

          if (sections.length === 0) return;

          let currentId = '';
          for (const section of sections) {
            const rect = section.getBoundingClientRect();
            if (rect.top <= 120) {
              currentId = '#' + section.id;
            }
          }
          if (currentId && location.hash !== currentId) {
            history.replaceState(null, '', currentId);
            updateActive();
          } else if (!currentId && location.hash) {
            history.replaceState(null, '', location.pathname);
            updateActive();
          }
          scrollTicking = false;
        });
        scrollTicking = true;
      }
    }

    const sidebarWithHandler = sidebar as HTMLElement & {
      _sidebarHandler?: EventListener;
      _scrollHandler?: EventListener;
    };
    const prevHandler = sidebarWithHandler._sidebarHandler;
    const prevScroll = sidebarWithHandler._scrollHandler;
    if (prevHandler) sidebar.removeEventListener('click', prevHandler);
    if (prevScroll) window.removeEventListener('scroll', prevScroll);
    sidebar.addEventListener('click', handler);
    sidebarWithHandler._sidebarHandler = handler as EventListener;
    window.addEventListener('scroll', onScroll, { passive: true });
    sidebarWithHandler._scrollHandler = onScroll as EventListener;

    updateActive();
  }

  function initSidebarToggle() {
    const btn = document.getElementById('sidebar-toggle-btn');
    const sidebar = document.querySelector('[data-sidebar]');
    const main = document.querySelector('[data-main-content]') as HTMLElement | null;
    if (!btn || !sidebar) return;

    function getSizes() {
      const mq = window.matchMedia('(max-width: 767px)');
      return {
        collapsed: mq.matches ? '50px' : '67px',
        expanded: mq.matches ? '200px' : '240px',
      };
    }

    function syncMainMargin() {
      if (!main) return;
      const isExpanded = sidebar!.classList.contains('expanded');
      const { collapsed, expanded } = getSizes();
      main.style.paddingLeft = isExpanded ? expanded : collapsed;
    }

    // 恢复或初始化侧边栏状态（无动画）
    const STORAGE_KEY = 'sidebar-expanded';
    const mq = window.matchMedia('(max-width: 767px)');
    const stored = localStorage.getItem(STORAGE_KEY);

    const sidebarEl = sidebar as HTMLElement;
    const prevTransition = sidebarEl.style.transition;
    sidebarEl.style.transition = 'none';

    if (stored !== null) {
      if (stored === 'true') {
        sidebar.classList.add('expanded');
      } else {
        sidebar.classList.remove('expanded');
      }
    } else {
      if (!mq.matches) {
        sidebar.classList.add('expanded');
      }
    }
    syncMainMargin();

    // 强制回流后恢复 transition
    void sidebarEl.offsetWidth;
    sidebarEl.style.transition = prevTransition;
    mq.addEventListener('change', syncMainMargin);

    btn.addEventListener('click', (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      sidebar.classList.toggle('expanded');
      const isExpanded = sidebar!.classList.contains('expanded');
      localStorage.setItem(STORAGE_KEY, String(isExpanded));
      syncMainMargin();
    });
  }

  initSidebarScroll();
  initSidebarToggle();
  document.addEventListener('astro:after-swap', () => {
    initSidebarScroll();
    initSidebarToggle();
  });
</script>
