---
export interface Tab {
  text: string;
  href: string;
}

export interface Props {
  tabs?: Tab[];
  currentPath?: string;
}

const { tabs = [], currentPath = '' } = Astro.props;
---

{
  tabs.length > 0 && (
    <div class="sticky top-[56px] z-30 border-b border-[#e0e0e0] dark:border-white/10 bg-white/80 dark:bg-[#1d1d1f]/80 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <nav class="flex gap-0 overflow-x-auto" aria-label="Section tabs">
          {tabs.map(({ text, href }) => {
            const isActive =
              currentPath === href ||
              currentPath.startsWith(href + '/') ||
              (href !== '/' && currentPath.startsWith(href));
            return (
              <a
                href={href}
                class:list={[
                  'whitespace-nowrap px-4 py-3 text-[14px] font-normal border-b-2 transition-colors duration-150',
                  isActive
                    ? 'border-[#0066cc] text-[#0066cc] font-semibold'
                    : 'border-transparent text-[#7a7a7a] hover:text-[#1d1d1f] dark:text-[#cccccc] dark:hover:text-white hover:border-[#e0e0e0]',
                ]}
              >
                {text}
              </a>
            );
          })}
        </nav>
      </div>
    </div>
  )
}
