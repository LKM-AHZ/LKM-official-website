---
import { Icon } from 'astro-icon/components';
import Button from '~/components/ui/Button.astro';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { Features as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline = await Astro.slots.render('tagline'),
  items = [],
  columns = 3,
  defaultIcon,

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

const columnsClass =
  columns === 4
    ? 'lg:grid-cols-4 md:grid-cols-3 sm:grid-cols-2'
    : columns === 3
      ? 'lg:grid-cols-3 sm:grid-cols-2'
      : columns === 2
        ? 'sm:grid-cols-2'
        : '';
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} classes={classes?.headline as Record<string, string>} />

  {
    items.length > 0 && (
      <div class:list={['grid gap-5 md:gap-6 gap-x-8', columnsClass]}>
        {items.map(({ title: itemTitle, description, icon, callToAction }) => (
          <div class="relative flex flex-col rounded-[12px] bg-base-200 border border-base-300 p-6 intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-hover">
            {(icon || defaultIcon) &&
              (/^tabler:/.test(icon || defaultIcon || '') ? (
                <Icon name={icon || defaultIcon} class="mb-6 w-12 h-12 text-primary" />
              ) : /^(https?:)/.test(icon || defaultIcon || '') ? (
                <img
                  src={icon || defaultIcon || ''}
                  alt={itemTitle || 'Avatar'}
                  class="mb-6 w-12 h-12 rounded-full object-cover shadow-sm border border-base-300"
                />
              ) : /^\//.test(icon || defaultIcon || '') ? (
                <img
                  src={icon || defaultIcon || ''}
                  alt={itemTitle || 'Avatar'}
                  class="mb-6 w-12 h-12 rounded-full object-cover shadow-sm border border-base-300"
                />
              ) : (
                <img
                  src={icon || defaultIcon || ''}
                  alt={itemTitle || 'Avatar'}
                  class="mb-6 w-12 h-12 rounded-full object-cover shadow-sm border border-base-300"
                />
              ))}
            <div class="text-[17px] font-semibold text-base-content leading-snug">{itemTitle}</div>
            {description && <p class="text-[14px] text-neutral mt-2 leading-relaxed" set:html={description} />}
            {callToAction && (
              <div class="mt-2">
                <Button {...callToAction} />
              </div>
            )}
          </div>
        ))}
      </div>
    )
  }
</WidgetWrapper>
