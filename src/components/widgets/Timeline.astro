---
// src/components/Timeline.astro
import TimelineItem from '~/components/ui/TimelineItem.astro';

interface TimelineData {
  year: string;
  title: string;
  description: string;
  iconColor?: string;
  iconName?: string;
}

interface Props {
  items: TimelineData[];
}

const { items } = Astro.props;
---

<div class="tl-wrap relative w-full">
  {/* 桌面端连接线 */}
  <svg class="tl-svg hidden md:block" aria-hidden="true" fill="none" data-tl-svg-desktop>
    <path data-tl-path fill="none" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round"></path>
  </svg>
  {/* 移动端连接线 */}
  <svg class="tl-svg md:hidden" aria-hidden="true" fill="none" data-tl-svg-mobile>
    <path data-tl-path fill="none" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round"></path>
  </svg>

  <ul class="relative w-full" data-tl-list>
    {
      items.map((item, index) => (
        <TimelineItem
          year={item.year}
          title={item.title}
          description={item.description}
          iconColor={item.iconColor}
          iconName={item.iconName}
          index={index}
          total={items.length}
        />
      ))
    }
  </ul>
</div>

<style>
  .tl-wrap {
    position: relative;
  }
  .tl-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>

<script>
  const CORNER_RADIUS = 20;

  function buildPath(dots) {
    if (dots.length < 2) return '';
    let d = `M ${dots[0].x},${dots[0].y}`;
    for (let i = 0; i < dots.length - 1; i++) {
      const a = dots[i];
      const b = dots[i + 1];
      const ymid = (a.y + b.y) / 2;
      const r = Math.min(CORNER_RADIUS, Math.abs(ymid - a.y), Math.abs(b.y - ymid));
      const dir = b.x > a.x ? 1 : -1;
      d += ` L ${a.x},${ymid - r}`;
      d += ` Q ${a.x},${ymid} ${a.x + dir * r},${ymid}`;
      d += ` L ${b.x - dir * r},${ymid}`;
      d += ` Q ${b.x},${ymid} ${b.x},${ymid + r}`;
      d += ` L ${b.x},${b.y}`;
    }
    return d;
  }

  function drawOne(wrap, svg, dotEls, straight) {
    const path = svg.querySelector('[data-tl-path]');
    if (!path) return;
    const wrapRect = wrap.getBoundingClientRect();
    const dots = Array.from(dotEls).map((dot: HTMLElement) => {
      const r = dot.getBoundingClientRect();
      return { x: r.left - wrapRect.left + r.width / 2, y: r.top - wrapRect.top + r.height / 2 };
    });
    if (dots.length < 2) { path.setAttribute('d', ''); return; }
    svg.setAttribute('width', String(wrapRect.width));
    svg.setAttribute('height', String(wrapRect.height));
    svg.setAttribute('viewBox', `0 0 ${wrapRect.width} ${wrapRect.height}`);
    if (straight) {
      path.setAttribute('d', dots.map((d, i) => `${i === 0 ? 'M' : 'L'} ${d.x},${d.y}`).join(' '));
    } else {
      path.setAttribute('d', buildPath(dots));
    }
  }

  function drawTimeline(wrap) {
    const list = wrap.querySelector('[data-tl-list]');
    if (!list) return;
    const svgDesktop = wrap.querySelector('[data-tl-svg-desktop]');
    if (svgDesktop) drawOne(wrap, svgDesktop, list.querySelectorAll('[data-tl-dot-desktop]'), false);
    const svgMobile = wrap.querySelector('[data-tl-svg-mobile]');
    if (svgMobile) drawOne(wrap, svgMobile, list.querySelectorAll('[data-tl-dot-mobile]'), true);
  }

  function initTimelines() {
    document.querySelectorAll('.tl-wrap').forEach((wrap) => {
      drawTimeline(wrap);
      new ResizeObserver(() => drawTimeline(wrap)).observe(wrap);
    });
  }

  document.addEventListener('astro:page-load', initTimelines);
</script>
