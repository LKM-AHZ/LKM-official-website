---
// src/components/Timeline.astro
import TimelineItem from '~/components/ui/TimelineItem.astro';

interface TimelineData {
  year: string;
  title: string;
  description: string;
  iconColor?: string; // 支持单个数据项自定义颜色
  iconName?: string;
}

interface Props {
  items: TimelineData[];
}

const { items } = Astro.props;
---

<div class="tl-wrap relative w-full">
  {/* 桌面端连接线：SVG 由脚本按圆点实际位置绘制（竖-圆角-横-圆角-竖，形状与折角一致） */}
  <svg class="tl-svg hidden md:block" aria-hidden="true" fill="none" data-tl-svg>
    <path data-tl-path fill="none" stroke="var(--color-base-300)" stroke-width="3" stroke-linecap="round"></path>
  </svg>

  <ul class="relative w-full" data-tl-list>
    {
      items.map((item, index) => (
        <TimelineItem
          year={item.year}
          title={item.title}
          description={item.description}
          iconColor={item.iconColor}
          iconName={item.iconName}
          index={index}
          total={items.length}
        />
      ))
    }
  </ul>
</div>

<style>
  .tl-wrap {
    position: relative;
  }
  /* SVG 覆盖整个时间线，位于圆点/文字下层 */
  .tl-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>

<script>
  const CORNER_RADIUS = 20; // 圆角半径(px)，与原折角一致

  function buildPath(dots: { x: number; y: number }[]): string {
    if (dots.length < 2) return '';
    let d = `M ${dots[0].x},${dots[0].y}`;
    for (let i = 0; i < dots.length - 1; i++) {
      const a = dots[i];
      const b = dots[i + 1];
      const ymid = (a.y + b.y) / 2;
      // 圆角半径不超过半段高度，避免相邻圆角重叠
      const r = Math.min(CORNER_RADIUS, Math.abs(ymid - a.y), Math.abs(b.y - ymid));
      const dir = b.x > a.x ? 1 : -1;
      // 竖直下降 → 圆角拐向 b.x → 水平 → 圆角拐向下 → 竖直到 b
      d += ` L ${a.x},${ymid - r}`;
      d += ` Q ${a.x},${ymid} ${a.x + dir * r},${ymid}`;
      d += ` L ${b.x - dir * r},${ymid}`;
      d += ` Q ${b.x},${ymid} ${b.x},${ymid + r}`;
      d += ` L ${b.x},${b.y}`;
    }
    return d;
  }

  function drawTimeline(wrap: Element) {
    const svg = wrap.querySelector<SVGSVGElement>('[data-tl-svg]');
    const path = wrap.querySelector<SVGPathElement>('[data-tl-path]');
    const list = wrap.querySelector<HTMLElement>('[data-tl-list]');
    if (!svg || !path || !list) return;

    // 仅桌面端绘制（SVG 在移动端 hidden）
    if (getComputedStyle(svg).display === 'none') return;

    const wrapRect = wrap.getBoundingClientRect();
    const dots = Array.from(list.querySelectorAll<HTMLElement>('[data-tl-dot]')).map((dot) => {
      const r = dot.getBoundingClientRect();
      return {
        x: r.left - wrapRect.left + r.width / 2,
        y: r.top - wrapRect.top + r.height / 2,
      };
    });

    if (dots.length < 2) {
      path.setAttribute('d', '');
      return;
    }

    svg.setAttribute('width', String(wrapRect.width));
    svg.setAttribute('height', String(wrapRect.height));
    svg.setAttribute('viewBox', `0 0 ${wrapRect.width} ${wrapRect.height}`);
    path.setAttribute('d', buildPath(dots));
  }

  function initTimelines() {
    const wraps = document.querySelectorAll('.tl-wrap');
    wraps.forEach((wrap) => {
      drawTimeline(wrap);
      // 尺寸变化时重绘（响应式、字体加载、内容高度变化）
      const ro = new ResizeObserver(() => drawTimeline(wrap));
      ro.observe(wrap);
    });
  }

  // 初次加载 + 每次视图切换（Astro view transitions）后重绘
  document.addEventListener('astro:page-load', initTimelines);
</script>
