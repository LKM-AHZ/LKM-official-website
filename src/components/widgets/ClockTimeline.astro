---
import { Icon } from 'astro-icon/components';

interface TimelineData {
  year: string;
  title: string;
  description: string;
  iconName?: string;
  iconColor?: string;
}

interface Props {
  items: TimelineData[];
}

const { items } = Astro.props;

// 提取简短年份用于钟表刻度标注
function shortYear(raw: string): string {
  const m = raw.match(/^\d{4}/);
  return m ? m[0] : raw;
}

const step = 360 / items.length;
const clockYears = items.map((i) => shortYear(i.year));
---

<div class="ct-root" data-clock-timeline>
  <div class="ct-layout">
    {/* ========== 左侧卡片区 ========== */}
    <div class="ct-cards-col" data-ct-cards-col>
      <div class="ct-cards-viewport">
        <div class="ct-cards-track" data-ct-cards-track>
          {
            items.map((item) => (
              <div class="ct-card">
                <div class="ct-card-body">
                  <div class="ct-card-year">{item.year}</div>
                  <div class="ct-card-title">{item.title}</div>
                  <div class="ct-card-desc">{item.description}</div>
                </div>
                {/* 移动端：卡片内文字右侧箭头 */}
                <div class="ct-arrows ct-arrows-mobile">
                  <button class="ct-arrow" data-ct-arrow="prev" aria-label="上一个">
                    <Icon name="tabler:chevron-up" class="h-6 w-6" />
                  </button>
                  <button class="ct-arrow" data-ct-arrow="next" aria-label="下一个">
                    <Icon name="tabler:chevron-down" class="h-6 w-6" />
                  </button>
                </div>
              </div>
            ))
          }
        </div>
      </div>
      {/* 桌面端：卡片外部右侧箭头 */}
      <div class="ct-arrows ct-arrows-desktop">
        <button class="ct-arrow" data-ct-arrow="prev" aria-label="上一个">
          <Icon name="tabler:chevron-up" class="h-6 w-6" />
        </button>
        <button class="ct-arrow" data-ct-arrow="next" aria-label="下一个">
          <Icon name="tabler:chevron-down" class="h-6 w-6" />
        </button>
      </div>
    </div>

    {/* ========== 右侧钟表区 ========== */}
    <div class="ct-clock-col" data-ct-clock-col>
      <div class="clock-face">
        {/* 指针 */}
        <div class="clock-pointer" data-ct-pointer>
          <div class="clock-pointer-line"></div>
        </div>
        {/* 刻度 */}
        {
          items.map((_item, i) => {
            const deg = i * step;
            return (
              <div class="clock-tick" style={`transform: rotate(${deg}deg)`}>
                <div class="clock-tick-mark" data-ct-tick={i}>
                  <span class="clock-tick-year">{clockYears[i]}</span>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</div>

<style>
  /* ===== 容器与布局 ===== */
  .ct-root {
    width: 100%;
  }

  .ct-layout {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* ===== 卡片列 ===== */
  .ct-cards-col {
    flex: 0 0 38%;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .ct-cards-viewport {
    overflow: hidden;
    height: 360px;
    flex: 1;
  }

  .ct-cards-track {
    display: flex;
    flex-direction: column;
    transition: transform 0.8s ease-in-out;
  }

  .ct-card {
    flex: 0 0 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 0.5rem;
    min-height: 360px;
    position: relative;
  }

  .ct-card-year {
    font-size: 28px;
    font-weight: 700;
    font-family: ui-monospace, monospace;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .ct-card-title {
    font-size: 30px;
    font-weight: 600;
    color: var(--color-base-content);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .ct-card-desc {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-neutral);
  }

  /* ===== 箭头按钮 ===== */
  .ct-arrows {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* 桌面端：卡片外右侧 */
  .ct-arrows-desktop {
    flex-shrink: 0;
  }

  /* 移动端：卡片内隐藏，移动端 media 中显示 */
  .ct-arrows-mobile {
    display: none;
  }

  .ct-card-body {
    flex: 1;
  }

  .ct-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--color-primary);
    background: var(--color-base-100);
    color: var(--color-primary);
    cursor: pointer;
    transition: all 0.2s;
  }

  .ct-arrow:hover {
    background: var(--color-primary);
    color: var(--color-primary-content);
  }

  /* ===== 钟表列 ===== */
  .ct-clock-col {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .clock-face {
    position: relative;
    width: 420px;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    border: 4px solid var(--color-primary);
    background-color: var(--color-base-100);
    box-shadow: 0 0 60px color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  /* 指针中心圆 */
  .clock-face::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-primary);
    transform: translate(-50%, -50%);
    z-index: 11;
  }

  /* 指针 */
  .clock-pointer {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 38%;
    height: 0;
    z-index: 10;
    transform-origin: left center;
    transition: transform 0.8s ease-in-out;
  }

  .clock-pointer-line {
    position: absolute;
    top: -3px;
    right: 0;
    width: 100%;
    height: 6px;
    background: var(--color-primary);
    border-radius: 3px;
  }

  /* 刻度 */
  .clock-tick {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 0;
    transform-origin: left center;
  }

  .clock-tick-mark {
    position: absolute;
    right: 40%;
    top: 50%;
    width: 5%;
    height: 2px;
    background-color: var(--color-primary);
    opacity: 0.25;
    transition:
      opacity 0.3s,
      height 0.3s,
      width 0.3s;
  }

  .clock-tick-active {
    opacity: 1;
    height: 3px;
    width: 7%;
  }

  .clock-tick-year {
    position: absolute;
    top: -11px;
    left: calc(90% + 4px);
    font-size: 22px;
    font-family: ui-monospace, monospace;
    color: var(--color-primary);
    white-space: nowrap;
    opacity: 0.5;
  }

  .clock-tick-active .clock-tick-year {
    opacity: 1;
    font-weight: 700;
    font-size: 24px;
  }

  /* ===== 移动端 ===== */
  @media (max-width: 767px) {
    .ct-layout {
      flex-direction: column;
      gap: 1rem;
    }

    /* 钟表放到卡片上方居中 */
    .ct-clock-col {
      width: 100%;
      order: -1;
      display: flex;
      justify-content: center;
      padding-top: 20px;
    }

    .ct-clock-col .clock-face {
      width: 260px;
      border-width: 3px;
    }

    .clock-pointer-line {
      height: 4px;
    }

    .clock-tick-mark {
      width: 3%;
    }

    .clock-tick-active {
      width: 5%;
    }

    .clock-tick-year {
      font-size: 14px;
      top: -7px;
    }

    .clock-tick-active .clock-tick-year {
      font-size: 15px;
    }

    /* 卡片区全宽 */
    .ct-cards-col {
      flex: 1 1 100%;
      width: 100%;
      position: relative;
    }

    .ct-cards-viewport {
      height: 380px;
    }

    .ct-card {
      min-height: 380px;
      padding: 0;
    }

    .ct-card-year {
      font-size: 22px;
    }
    .ct-card-title {
      font-size: 22px;
    }
    .ct-card-desc {
      font-size: 14px;
    }

    /* 箭头上下排列，紧贴卡片文字右侧 */
    .ct-card {
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
      padding-right: 0.5rem;
    }

    .ct-arrows-desktop {
      display: none;
    }

    .ct-arrows-mobile {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      flex-shrink: 0;
    }
  }
</style>

<script>
  function initClockTimeline(root: HTMLElement) {
    const track = root.querySelector('[data-ct-cards-track]') as HTMLElement;
    const clockCol = root.querySelector('[data-ct-clock-col]') as HTMLElement;
    const allPrevBtns = root.querySelectorAll('[data-ct-arrow="prev"]');
    const allNextBtns = root.querySelectorAll('[data-ct-arrow="next"]');

    if (!track || !clockCol || allPrevBtns.length === 0 || allNextBtns.length === 0) return;

    const total = track.querySelectorAll('.ct-card').length;
    let currentIndex = 0;
    const angleStep = 360 / total;
    const viewport = track.parentElement as HTMLElement;

    function getCardHeight(): number {
      const first = track.querySelector('.ct-card') as HTMLElement;
      return first ? first.getBoundingClientRect().height : viewport.clientHeight;
    }

    function update() {
      const cardHeight = getCardHeight();
      track.style.transform = `translate3d(0, -${currentIndex * cardHeight}px, 0)`;

      const pointer = clockCol.querySelector('.clock-pointer') as HTMLElement;
      if (pointer) {
        pointer.style.transform = `rotate(${currentIndex * angleStep}deg)`;
      }

      clockCol.querySelectorAll('[data-ct-tick]').forEach((el) => {
        const idx = parseInt(el.getAttribute('data-ct-tick') || '0');
        el.classList.toggle('clock-tick-active', idx === currentIndex);
      });
    }

    allPrevBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        currentIndex = currentIndex <= 0 ? total - 1 : currentIndex - 1;
        update();
      });
    });

    allNextBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        currentIndex = currentIndex >= total - 1 ? 0 : currentIndex + 1;
        update();
      });
    });

    update();
  }

  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('[data-clock-timeline]').forEach((el) => {
      initClockTimeline(el as HTMLElement);
    });
  });
</script>
