---
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';

import type { Hero as Props } from '~/types';
import styles from './Hero.module.css';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,

  content = await Astro.slots.render('content'),
  actions = await Astro.slots.render('actions'),
  image = await Astro.slots.render('image'),

  id,
  bg = await Astro.slots.render('bg'),
  nextSectionId,
} = Astro.props;
---

<section
  class="relative not-prose h-screen min-h-screen flex flex-col justify-center overflow-hidden"
  {...id ? { id } : {}}
  data-hero-section
>
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : null}
    </slot>
  </div>
  <div class={styles.heroInner}>
    <div class="py-16 md:py-[80px]">
      <div class={styles.heroBody}>
        {
          tagline && (
            <p
              class="text-base text-secondary dark:text-blue-200 font-bold tracking-wide uppercase intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
              set:html={tagline}
            />
          )
        }
        {
          title && (
            <h1
              class={`${styles.heroHeading} font-heading leading-tighter tracking-tighter intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade`}
              set:html={title}
            />
          )
        }
        <div class="max-w-3xl mx-auto">
          {
            subtitle && (
              <p
                class={`${styles.heroSubtitle} text-muted intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade`}
                set:html={subtitle}
              />
            )
          }
          {
            actions && (
              <div class="max-w-xs sm:max-w-md m-auto flex flex-nowrap flex-col sm:flex-row sm:justify-center gap-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
                {Array.isArray(actions) ? (
                  actions.map((action) => (
                    <div class="flex w-full sm:w-auto">
                      <Button {...(action || {})} class="w-full sm:mb-0" />
                    </div>
                  ))
                ) : (
                  <Fragment set:html={actions} />
                )}
              </div>
            )
          }
        </div>
        {content && <Fragment set:html={content} />}
      </div>
      {
        image && (
          <div
            class="intersect-once intersect-no-queue intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          >
            <div class="relative m-auto max-w-5xl">
              {typeof image === 'string' ? (
                <Fragment set:html={image} />
              ) : (
                <Image
                  class="mx-auto rounded-md w-full"
                  widths={[400, 768, 1024, 2040]}
                  sizes="(max-width: 767px) 400px, (max-width: 1023px) 768px, (max-width: 2039px) 1024px, 2040px"
                  loading="eager"
                  fetchpriority="high"
                  width={1024}
                  height={576}
                  format="webp"
                  {...image}
                />
              )}
            </div>
          </div>
        )
      }
    </div>
  </div>

  <!-- 下拉按钮 -->
  {
    nextSectionId && (
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10">
        <button
          type="button"
          class="flex flex-col items-center gap-1 text-[#7a7a7a] dark:text-[#cccccc] hover:text-[#0066cc] dark:hover:text-[#2997ff] transition-colors cursor-pointer"
          data-hero-scroll-down
          aria-label="向下滚动"
        >
          <svg class="w-5 h-5 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </button>
      </div>
    )
  }
</section>

{
  nextSectionId && (
    <script define:vars={{ nextSectionId }}>
      (() => {
        const hero = document.querySelector('[data-hero-section]');
        if (!hero) return;
        const target = document.getElementById(nextSectionId);
        if (!target) return;

        const scrollTo = (to) => {
          if ('scrollBehavior' in document.documentElement.style) {
            window.scrollTo({ top: to.getBoundingClientRect().top + window.scrollY, behavior: 'smooth' });
          } else {
            window.scrollTo(0, to.getBoundingClientRect().top + window.scrollY);
          }
        };

        const scrollDown = () => scrollTo(target);

        // 下拉按钮
        hero.querySelector('[data-hero-scroll-down]')?.addEventListener('click', scrollDown);

        // 滚轮事件
        hero.addEventListener('wheel', (e) => {
          if (e.deltaY > 0) {
            e.preventDefault();
            scrollDown();
          }
        }, { passive: false });

        // 键盘事件
        hero.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowDown' || e.key === 'PageDown' || e.key === ' ') {
            e.preventDefault();
            scrollDown();
          }
        });

        // 触屏下滑
        let touchStartY = 0;
        hero.addEventListener('touchstart', (e) => {
          touchStartY = e.touches[0].clientY;
        }, { passive: true });
        hero.addEventListener('touchend', (e) => {
          const dy = touchStartY - e.changedTouches[0].clientY;
          if (dy > 50) scrollDown();
        }, { passive: true });
      })();
    </script>
  )
}
