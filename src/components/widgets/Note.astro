---
import { Icon } from 'astro-icon/components';

export interface Props {
  icon?: string;
  title?: string;
  description?: string;
}

const {
  icon = 'tabler:info-square',
  title = await Astro.slots.render('title'),
  description = await Astro.slots.render('description'),
} = Astro.props;
---

<section class="bg-[#f5f5f7] dark:bg-[#272729] not-prose">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 text-[17px] text-center text-[#1d1d1f] dark:text-white">
    <Icon name={icon} class="w-4 h-4 inline-block align-text-bottom text-[#0066cc]" />
    <span class="font-semibold" set:html={title} />
    <Fragment set:html={description} />
  </div>
</section>
