---
import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';

import Image from '~/components/common/Image.astro';

import { findImage } from '~/utils/images';
import { getPermalink, transitionName } from '~/utils/permalinks';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const image = await findImage(post.image);

const link = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';

const imageName = transitionName('post-image', post.permalink);
const titleName = transitionName('post-title', post.permalink);
---

<article
  class="mb-6 transition  card-hover"
>
  <div class="relative md:h-64 bg-base-300 rounded-[16px] overflow-hidden mb-5" transition:name={imageName}>
    {
      image &&
        (link ? (
          <a href={link}>
            <Image
              src={image}
              class="w-full md:h-full object-cover rounded-[16px]"
              widths={[400, 900]}
              width={900}
              height={506}
              sizes="(max-width: 900px) 400px, 900px"
              alt={post.title}
              format="webp"
              loading="lazy"
              decoding="async"
            />
          </a>
        ) : (
          <Image
            src={image}
            class="w-full md:h-full object-cover rounded-[16px]"
            widths={[400, 900]}
            width={900}
            height={506}
            sizes="(max-width: 900px) 400px, 900px"
            alt={post.title}
            format="webp"
            loading="lazy"
            decoding="async"
          />
        ))
    }
  </div>

  <h3 class="text-[17px] font-semibold leading-snug mb-1 font-heading text-base-content" transition:name={titleName}>
    {
      link ? (
        <a class="inline-block hover:text-primary transition ease-in duration-200" href={link}>
          {post.title}
        </a>
      ) : (
        post.title
      )
    }
  </h3>

  <p class="text-[14px] text-neutral leading-relaxed">{post.excerpt}</p>
</article>
