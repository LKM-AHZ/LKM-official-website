---
import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';

import Image from '~/components/common/Image.astro';

import { findImage } from '~/utils/images';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const image = await findImage(post.image);

const link = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
---

<article
  class="mb-6 transition intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
>
  <div class="relative md:h-64 bg-gray-100 dark:bg-gray-700 rounded-[18px] overflow-hidden mb-5">
    {
      image &&
        (link ? (
          <a href={link}>
            <Image
              src={image}
              class="w-full md:h-full object-cover rounded-[18px]"
              widths={[400, 900]}
              width={900}
              height={506}
              sizes="(max-width: 900px) 400px, 900px"
              alt={post.title}
              format="webp"
              loading="lazy"
              decoding="async"
            />
          </a>
        ) : (
          <Image
            src={image}
            class="w-full md:h-full object-cover rounded-[18px]"
            widths={[400, 900]}
            width={900}
            height={506}
            sizes="(max-width: 900px) 400px, 900px"
            alt={post.title}
            format="webp"
            loading="lazy"
            decoding="async"
          />
        ))
    }
  </div>

  <h3 class="text-[17px] font-semibold leading-snug mb-1 font-heading text-[#1d1d1f] dark:text-white">
    {
      link ? (
        <a
          class="inline-block hover:text-[#0066cc] dark:hover:text-[#2997ff] transition ease-in duration-200"
          href={link}
        >
          {post.title}
        </a>
      ) : (
        post.title
      )
    }
  </h3>

  <p class="text-[14px] text-[#7a7a7a] dark:text-[#cccccc] leading-relaxed">{post.excerpt}</p>
</article>
