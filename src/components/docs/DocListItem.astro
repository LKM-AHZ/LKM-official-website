---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  doc: CollectionEntry<'docs'>;
  href: string;
}

const { doc, href } = Astro.props;
const { data } = doc;
---

<li
  class="border-b border-base-300 last:border-0 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
>
  <a
    href={href}
    class="flex items-center justify-between px-2 py-4 -mx-2 rounded-lg hover:bg-base-200 transition-colors group"
  >
    <div class="flex items-center gap-3 min-w-0">
      <Icon
        name="tabler:file-text"
        class="w-5 h-5 flex-shrink-0 text-primary group-hover:scale-110 transition-transform"
      />
      <span class="text-[15px] font-medium text-base-content truncate group-hover:text-primary transition-colors">
        {data.title}
      </span>
    </div>
    <div class="flex items-center gap-3 flex-shrink-0 ml-4">
      {
        data.tags && data.tags.length > 0 && (
          <span class="hidden sm:flex items-center gap-1.5">
            {data.tags.slice(0, 2).map((tag) => (
              <span class="text-xs px-2 py-0.5 rounded-full bg-base-300 text-neutral">{tag}</span>
            ))}
          </span>
        )
      }
      <span class="flex items-center gap-1 text-xs text-neutral flex-shrink-0">
        <Icon name="tabler:clock" class="w-3 h-3" />
        <time datetime={String(data.publishDate)}>{getFormattedDate(data.publishDate)}</time>
      </span>
    </div>
  </a>
</li>
