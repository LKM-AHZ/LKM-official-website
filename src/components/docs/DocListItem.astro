---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  doc: CollectionEntry<'docs'>;
  href: string;
}

const { doc, href } = Astro.props;
const { data } = doc;
---

<li class="border-b border-gray-100 dark:border-gray-800 last:border-0">
  <a
    href={href}
    class="flex items-center justify-between px-2 py-4 -mx-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group"
  >
    <div class="flex items-center gap-3 min-w-0">
      <Icon
        name="tabler:file-text"
        class="w-5 h-5 flex-shrink-0 text-[#0066cc] dark:text-[#2997ff] group-hover:scale-110 transition-transform"
      />
      <span class="text-[15px] font-medium text-[#1d1d1f] dark:text-white truncate group-hover:text-[#0066cc] dark:group-hover:text-[#2997ff] transition-colors">
        {data.title}
      </span>
    </div>
    <div class="flex items-center gap-3 flex-shrink-0 ml-4">
      {
        data.tags && data.tags.length > 0 && (
          <span class="hidden sm:flex items-center gap-1.5">
            {data.tags.slice(0, 2).map((tag) => (
              <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-[#7a7a7a] dark:text-[#999]">
                {tag}
              </span>
            ))}
          </span>
        )
      }
      <span class="flex items-center gap-1 text-xs text-[#7a7a7a] dark:text-[#999] flex-shrink-0">
        <Icon name="tabler:clock" class="w-3 h-3" />
        <time datetime={String(data.publishDate)}>{getFormattedDate(data.publishDate)}</time>
      </span>
    </div>
  </a>
</li>
