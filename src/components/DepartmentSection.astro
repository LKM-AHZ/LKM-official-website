---
import Section from '~/components/widgets/Section.astro';

export interface Props {
  id: string;
  title: string;
  borderColor: string;
  desc: string;
  /** 设为 true 可跳过默认的三列网格布局（如用于子分组布局） */
  noGrid?: boolean;
}

const { id, title, borderColor, desc, noGrid = false } = Astro.props;
---

<Section id={id}>
  <div class="max-w-7xl mx-auto">
    <h3 class="text-xl font-bold mb-5 text-center">
      <span class="border-b-2 pb-1" style={`border-color: ${borderColor}`}>{title}</span>
    </h3>
    {
      desc && (
        <p class="max-w-3xl mx-auto mb-9 px-6 py-4 bg-base-200 border border-base-300 rounded-[8px] text-center text-[14px] text-neutral leading-relaxed card-hover ">
          {desc}
        </p>
      )
    }
    {
      noGrid ? (
        <slot />
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <slot />
        </div>
      )
    }
  </div>
</Section>
