---
import Section from '~/components/widgets/Section.astro';

export interface Props {
  id: string;
  title: string;
  borderColor: string;
  desc: string;
  /** Set true to skip the default 3-column grid (e.g. for sub-group layouts) */
  noGrid?: boolean;
}

const { id, title, borderColor, desc, noGrid = false } = Astro.props;
---

<Section id={id}>
  <div class="max-w-5xl mx-auto">
    <h3 class="text-xl font-bold mb-2 text-center">
      <span class="border-b-2 pb-1" style={`border-color: ${borderColor}`}>{title}</span>
    </h3>
    {
      desc && (
        <p class="max-w-3xl mx-auto mb-6 px-6 py-4 bg-[#f5f5f7] dark:bg-[#1a1a1c] rounded-[11px] text-center text-[14px] text-[#7a7a7a] dark:text-[#cccccc] leading-relaxed">
          {desc}
        </p>
      )
    }
    {
      noGrid ? (
        <slot />
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <slot />
        </div>
      )
    }
  </div>
</Section>
