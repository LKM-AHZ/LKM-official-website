---
import { UI } from 'astrowind:config';
---

<script is:inline define:vars={{ defaultTheme: UI.theme }}>
  if (window.basic_script) {
    return;
  }

  window.basic_script = true;

  function applyTheme(theme) {
    document.documentElement.setAttribute('data-theme', theme === 'dark' ? 'lkm-dark' : 'lkm-light');
  }

  function updateToggleThemeIcon() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'lkm-dark';
    const toggle = document.querySelector('[data-aw-toggle-color-scheme]');
    if (toggle) {
      const useEl = toggle.querySelector('use');
      if (useEl) {
        const href = useEl.getAttribute('href') || '';
        if (isDark) {
          useEl.setAttribute('href', href.replace('#tabler:sun', '#tabler:moon'));
        } else {
          useEl.setAttribute('href', href.replace('#tabler:moon', '#tabler:sun'));
        }
      }
    }
  }

  // ApplyColorMode.astro already sets the initial theme before paint.
  // Here we re-apply from localStorage to keep theme toggle state consistent
  // after View Transitions (astro:after-swap).
  const initTheme = function () {
    const theme = localStorage.theme;
    if (theme === 'dark') {
      applyTheme('dark');
    } else if (theme === 'light') {
      applyTheme('light');
    } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
      applyTheme('dark');
    }
    updateToggleThemeIcon();
  };
  initTheme();

  function attachEvent(selector, event, fn) {
    const matches = typeof selector === 'string' ? document.querySelectorAll(selector) : selector;
    if (matches && matches.length) {
      matches.forEach((elem) => {
        elem.addEventListener(event, (e) => fn(e, elem), false);
      });
    }
  }

  function closeMobileMenu() {
    document.querySelector('[data-aw-toggle-menu]')?.classList.remove('expanded');
    document.body.classList.remove('overflow-hidden');
    document.getElementById('header')?.classList.remove('h-screen');
    document.getElementById('header')?.classList.remove('expanded');
    document.getElementById('header')?.classList.remove('bg-base-100');
    document.querySelector('#header nav')?.classList.add('hidden');
    document.querySelector('#header > div > div:last-child')?.classList.add('hidden');
  }

  // Scroll state shared between the one-time scroll listener and the
  // per-navigation initial call to applyHeaderStylesOnScroll().
  let lastKnownScrollPosition = window.scrollY;
  let ticking = true;

  function applyHeaderStylesOnScroll() {
    const header = document.querySelector('#header[data-aw-sticky-header]');
    if (!header) return;
    if (lastKnownScrollPosition > 60 && !header.classList.contains('scroll')) {
      header.classList.add('scroll');
    } else if (lastKnownScrollPosition <= 60 && header.classList.contains('scroll')) {
      header.classList.remove('scroll');
    }
    ticking = false;
  }

  // Guard so that event subscriptions bound to persistent elements
  // (persist header, document, matchMedia) are only attached once and do
  // not stack up on every astro:after-swap navigation.
  let eventsBound = false;

  const onLoad = function () {
    if (!eventsBound) {
      attachEvent('#header nav', 'click', closeMobileMenu);

      attachEvent('[data-aw-toggle-menu]', 'click', function (_, elem) {
        elem.classList.toggle('expanded');
        document.body.classList.toggle('overflow-hidden');
        document.getElementById('header')?.classList.toggle('h-screen');
        document.getElementById('header')?.classList.toggle('expanded');
        document.getElementById('header')?.classList.toggle('bg-base-100');
        document.querySelector('#header nav')?.classList.toggle('hidden');
        document.querySelector('#header > div > div:last-child')?.classList.toggle('hidden');
      });

      attachEvent('[data-aw-toggle-color-scheme]', 'click', function () {
        if (defaultTheme.endsWith(':only')) {
          return;
        }

        const isDark = document.documentElement.getAttribute('data-theme') === 'lkm-dark';
        const next = isDark ? 'lkm-light' : 'lkm-dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.theme = next === 'lkm-dark' ? 'dark' : 'light';
        updateToggleThemeIcon();
      });

      // Delegated on document so it survives View Transitions and still
      // works for share buttons created fresh on each article page,
      // without rebinding (and thus stacking) on every navigation.
      document.addEventListener('click', function (e) {
        const elem = e.target.closest?.('[data-aw-social-share]');
        if (!elem) return;

        const network = elem.getAttribute('data-aw-social-share');
        const url = encodeURIComponent(elem.getAttribute('data-aw-url'));
        const text = encodeURIComponent(elem.getAttribute('data-aw-text'));

        let href;
        switch (network) {
          case 'facebook':
            href = `https://www.facebook.com/sharer.php?u=${url}`;
            break;
          case 'twitter':
            href = `https://twitter.com/intent/tweet?url=${url}&text=${text}`;
            break;
          case 'linkedin':
            href = `https://www.linkedin.com/shareArticle?mini=true&url=${url}&title=${text}`;
            break;
          case 'whatsapp':
            href = `https://wa.me/?text=${text}%20${url}`;
            break;
          case 'mail':
            href = `mailto:?subject=%22${text}%22&body=${text}%20${url}`;
            break;

          default:
            return;
        }

        const newlink = document.createElement('a');
        newlink.target = '_blank';
        newlink.href = href;
        newlink.click();
      });

      const screenSize = window.matchMedia('(max-width: 767px)');
      screenSize.addEventListener('change', closeMobileMenu);

      attachEvent([document], 'scroll', function () {
        lastKnownScrollPosition = window.scrollY;

        if (!ticking) {
          window.requestAnimationFrame(() => {
            applyHeaderStylesOnScroll();
          });
          ticking = true;
        }
      });

      eventsBound = true;
    }

    // Runs on every navigation: reflect current page scroll state and
    // handle the URL hash anchor for View Transitions SPA nav.
    lastKnownScrollPosition = window.scrollY;
    applyHeaderStylesOnScroll();
    handleAnchorScroll();
  };

  // Scroll to element matching the URL hash (for View Transitions SPA nav)
  function handleAnchorScroll() {
    const hash = location.hash;
    if (hash) {
      let attempts = 0;
      const maxAttempts = 10;
      const tryScroll = () => {
        const target = document.querySelector(hash);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
        } else if (attempts < maxAttempts) {
          attempts++;
          requestAnimationFrame(tryScroll);
        }
      };
      // Defer to ensure DOM is fully painted after View Transition
      requestAnimationFrame(() => {
        requestAnimationFrame(tryScroll);
      });
    }
  }

  const onPageShow = function () {
    document.documentElement.classList.add('motion-safe:scroll-smooth');
    closeMobileMenu();
  };

  window.onload = onLoad;
  window.onpageshow = onPageShow;

  document.addEventListener('astro:after-swap', () => {
    initTheme();
    onLoad();
    onPageShow();
  });
</script>

