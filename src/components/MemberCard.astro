---
import type { ImageMetadata } from 'astro';

export interface Props {
  name: string;
  avatar?: ImageMetadata;
  role?: string;
  desc?: string;
  dream?: string;
  quote?: string;
  /** "sm" (default) for department members, "lg" for founder-type cards */
  size?: 'sm' | 'lg';
}

const { name, avatar, role, desc, dream, quote, size = 'sm' } = Astro.props;
const isLg = size === 'lg';
---

<div class="rounded-[18px] border border-[#e0e0e0] dark:border-white/8 bg-white dark:bg-[#1a1a1c]">
  <div class="p-5 flex flex-col items-center text-center">
    <div class="mb-3">
      {
        avatar ? (
          <img
            src={avatar.src}
            alt={name}
            class={isLg ? 'w-24 h-24 rounded-full object-cover' : 'w-16 h-16 rounded-full object-cover'}
          />
        ) : (
          <div
            class={
              isLg
                ? 'w-24 h-24 rounded-full bg-[#d1d1d6] text-[#98989d] dark:bg-[#3a3a3c] flex items-center justify-center text-lg font-semibold'
                : 'w-16 h-16 rounded-full bg-[#d1d1d6] text-[#98989d] dark:bg-[#3a3a3c] flex items-center justify-center text-lg font-semibold'
            }
          >
            {name.replace('七月', '').charAt(0) || name.charAt(0)}
          </div>
        )
      }
    </div>
    {
      isLg ? (
        <h2 class="text-[21px] font-semibold text-[#1d1d1f] dark:text-white">{name}</h2>
      ) : (
        <h4 class="font-bold text-lg text-[#1d1d1f] dark:text-white">{name}</h4>
      )
    }
    {
      role && (
        <span class={isLg ? 'text-[#0066cc] font-semibold' : 'text-xs text-[#7a7a7a] dark:text-[#cccccc]'}>{role}</span>
      )
    }
    {desc && <p class="text-xs text-[#7a7a7a] dark:text-[#cccccc] mt-2">{desc}</p>}
    {dream && <p class="text-xs text-[#0066cc]/80 dark:text-[#2997ff]/80 mt-1 italic">{dream}</p>}
    {quote && <p class="text-xs text-[#0066cc]/70 dark:text-[#2997ff]/70 mt-1">{quote}</p>}
  </div>
</div>
