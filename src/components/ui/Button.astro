---
import { Icon } from 'astro-icon/components';
import type { CallToAction as Props } from '~/types';

const {
  variant = 'secondary',
  target,
  text = Astro.slots.render('default'),
  icon = '',
  class: className = '',
  type,
  href,
  ...rest
} = Astro.props;

const variantClass =
  {
    primary: 'btn-primary',
    secondary: 'btn-neutral',
    tertiary: 'btn-ghost',
    link: 'btn-link',
  }[variant] || 'btn-neutral';

const isSubmit = type === 'button' || type === 'submit' || type === 'reset';
const classes = ['btn', variantClass, 'pointer-events-auto', className].filter(Boolean).join(' ');
---

{
  href ? (
    <a
      class={classes}
      href={href}
      {...(target ? { target } : {})}
      {...(target === '_blank' ? { rel: 'noopener noreferrer' } : {})}
      {...rest}
    >
      <Fragment set:html={text} />
      {icon && <Icon name={icon} class="w-5 h-5 inline-block" />}
    </a>
  ) : (
    <button class={classes} {...(isSubmit ? { type } : { type: 'button' })} {...rest}>
      <Fragment set:html={text} />
      {icon && <Icon name={icon} class="w-5 h-5 inline-block" />}
    </button>
  )
}
