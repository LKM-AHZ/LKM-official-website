---
import type { Form as Props } from '~/types';
import Button from '~/components/ui/Button.astro';

const { inputs, textarea, disclaimer, button = 'Contact us', description = '' } = Astro.props;
---

<form id="contact-form" method="POST" action="#">
  <div id="form-message" class="hidden mb-4 p-3 rounded-lg text-center text-sm"></div>
  {
    inputs &&
      inputs.map(
        ({ type = 'text', name, label = '', autocomplete = 'on', placeholder = '' }) =>
          name && (
            <div class="mb-6">
              {label && (
                <label for={name} class="block text-[14px] font-medium text-[#1d1d1f] dark:text-white mb-1">
                  {label}
                </label>
              )}
              <input
                type={type}
                name={name}
                id={name}
                autocomplete={autocomplete}
                placeholder={placeholder}
                class="py-3 px-4 block w-full text-[17px] rounded-[11px] border border-[#e0e0e0] dark:border-white/10 bg-white dark:bg-[#272729] text-[#1d1d1f] dark:text-white placeholder:text-[#7a7a7a] focus:outline-none focus:ring-2 focus:ring-[#0071e3] focus:ring-offset-1"
              />
            </div>
          )
      )
  }

  {
    textarea && (
      <div>
        <label for="textarea" class="block text-[14px] font-medium text-[#1d1d1f] dark:text-white mb-1">
          {textarea.label}
        </label>
        <textarea
          id="textarea"
          name={textarea.name ? textarea.name : 'message'}
          rows={textarea.rows ? textarea.rows : 4}
          placeholder={textarea.placeholder}
          class="py-3 px-4 block w-full text-[17px] rounded-[11px] border border-[#e0e0e0] dark:border-white/10 bg-white dark:bg-[#272729] text-[#1d1d1f] dark:text-white placeholder:text-[#7a7a7a] focus:outline-none focus:ring-2 focus:ring-[#0071e3] focus:ring-offset-1"
        />
      </div>
    )
  }

  {
    disclaimer && (
      <div class="mt-3 flex items-start">
        <div class="flex mt-0.5">
          <input
            id="disclaimer"
            name="disclaimer"
            type="checkbox"
            class="cursor-pointer mt-1 w-4 h-4 accent-[#0066cc]"
          />
        </div>
        <div class="ml-3">
          <label for="disclaimer" class="cursor-pointer select-none text-[14px] text-[#7a7a7a] dark:text-[#cccccc]">
            {disclaimer.label}
          </label>
        </div>
      </div>
    )
  }

  {
    button && (
      <div class="mt-10 grid">
        <Button variant="primary" type="submit">
          {button}
        </Button>
      </div>
    )
  }

  {
    description && (
      <div class="mt-3 text-center">
        <p class="text-[12px] text-[#7a7a7a] dark:text-[#cccccc]">{description}</p>
      </div>
    )
  }
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', function (this: HTMLFormElement, e: SubmitEvent) {
      e.preventDefault();
      const msg = document.getElementById('form-message');
      if (msg) {
        msg.className =
          'mb-4 p-3 rounded-lg text-center text-sm bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200';
        msg.textContent = '此表单为静态展示，暂不支持在线提交。请通过其他方式联系我们。';
      }
    });
  }
</script>
