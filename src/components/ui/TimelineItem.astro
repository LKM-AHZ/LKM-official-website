---
// src/components/TimelineItem.astro
import { Icon } from 'astro-icon/components';

interface Props {
  year: string;
  title: string;
  description: string;
  index: number;
  total: number;
  iconName?: string; // 新增：允许自定义 Icon 名字
  iconColor?: string; // 新增：允许控制颜色 class
}

const {
  year,
  title,
  description,
  index,
  total,
  iconName = 'tabler:circle-check', // 设定一个默认图标
  iconColor = 'text-primary',
} = Astro.props;

const isEven = index % 2 === 0;
const showStartLine = index > 0;
const showEndLine = index < total - 1;
---

<li>
  {showStartLine && <hr />}

  <div class="timeline-middle">
    <Icon name={iconName} class:list={['h-8 w-8', iconColor]} />
  </div>

  <div class:list={[isEven ? 'timeline-start mb-10 md:text-end' : 'timeline-end md:mb-10']}>
    <time class="font-mono text-[12px] text-[#7a7a7a] dark:text-[#cccccc]">{year}</time>
    <div class="text-[17px] font-semibold text-[#1d1d1f] dark:text-white">{title}</div>
    <p class="text-[14px] text-[#7a7a7a] dark:text-[#cccccc] leading-relaxed max-w-xl">{description}</p>
  </div>

  {showEndLine && <hr />}
</li>
