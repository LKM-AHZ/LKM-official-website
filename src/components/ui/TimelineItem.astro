---
// src/components/TimelineItem.astro
import { Icon } from 'astro-icon/components';

interface Props {
  year: string;
  title: string;
  description: string;
  index: number;
  total: number;
  iconName?: string;
  iconColor?: string;
}

const { year, title, description, index, iconName = 'tabler:circle-check', iconColor = 'text-primary' } = Astro.props;

const isEven = index % 2 === 0;
// isEven: 圆点在 1/3、文字在右宽侧；否则圆点在 2/3、文字在左宽侧
// 连接线由 Timeline.astro 的 SVG 依据圆点实际位置动态绘制
---

<li class="tl-item">
  {/* ===================== 移动端（<md）：圆环样式，连接线由 SVG 绘制 ===================== */}
  <div class="relative pb-10 last:pb-0 md:hidden">
    <span class="tl-dot-mobile" data-tl-dot-mobile>
      <Icon name={iconName} class:list={['h-5 w-5', iconColor]} />
    </span>
    <div class="pl-12">
      <time class="font-mono text-[12px] text-neutral">{year}</time>
      <div class="text-[17px] font-semibold text-base-content">{title}</div>
      <p class="text-[14px] text-neutral leading-relaxed max-w-xl">{description}</p>
    </div>
  </div>

  {/* ===================== 桌面端（≥md）：圆点@1/3·2/3，文字宽侧；连接线由 SVG 画 ===================== */}
  <div class:list={['tl-row hidden md:block', isEven ? 'tl-left' : 'tl-right']}>
    {/* 圆点：锚定 1/3 或 2/3，垂直居中。data-tl-dot 供 SVG 脚本定位 */}
    <span class="tl-circle" data-tl-dot data-tl-dot-desktop>
      <Icon name={iconName} class:list={['h-6 w-6', iconColor]} />
    </span>
    {/* 文字：宽侧 */}
    <div class:list={['tl-content', isEven ? 'text-start' : 'text-end']}>
      <time class="font-mono text-[12px] text-neutral">{year}</time>
      <div class="text-[17px] font-semibold text-base-content">{title}</div>
      <p class="text-[14px] text-neutral leading-relaxed">{description}</p>
    </div>
  </div>
</li>

<style>
  /* ===== 桌面端节点行：相对定位容器，圆点绝对锚定百分比 ===== */
  .tl-row {
    position: relative;
    min-height: 3.5rem;
  }

  /* 圆点：锚定百分比，垂直居中 */
  .tl-circle {
    position: absolute;
    top: 50%;
    z-index: 2;
    display: flex;
    height: 2.75rem;
    width: 2.75rem;
    transform: translate(-50%, -50%);
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 2px solid var(--color-primary);
    background-color: var(--color-base-100);
  }
  .tl-left .tl-circle {
    left: 25%;
  }
  .tl-right .tl-circle {
    left: 75%;
  }

  /* 文字：宽侧，让开圆点；外侧留白，使文字向中间收 */
  .tl-content {
    padding: 0.75rem 0;
  }
  .tl-left .tl-content {
    margin-left: calc(25% + 2.25rem);
    margin-right: 10%;
  }
  .tl-right .tl-content {
    margin-right: calc(25% + 2.25rem);
    margin-left: 10%;
  }
  .tl-right .tl-content p {
    margin-left: auto;
  }

  /* 移动端：圆圈置顶，SVG 画线连接 */
  .tl-dot-mobile {
    position: absolute;
    left: 0;
    top: 0;
    z-index: 2;
    display: flex;
    height: 2.75rem;
    width: 2.75rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 2px solid var(--color-primary);
    background-color: var(--color-base-100);
  }
</style>
