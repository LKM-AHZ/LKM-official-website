---
import PageLayout from '~/layouts/PageLayout.astro';
import TopNav from '~/components/widgets/TopNav.astro';
import Sidebar from '~/components/widgets/Sidebar.astro';

import type { MetaData } from '~/types';
import type { Tab } from '~/components/widgets/TopNav.astro';

export interface SidebarLink {
  text: string;
  href: string;
  icon?: string;
}

export interface Props {
  metadata?: MetaData;
  /** 全局顶栏标签 */
  topTabs?: Tab[];
  /** 当前分区侧边栏链接 */
  sidebarLinks?: SidebarLink[];
  currentPath?: string;
}

const DEFAULT_ICON = 'tabler:link';

const { metadata, topTabs = [], sidebarLinks = [], currentPath = '' } = Astro.props;
---

<PageLayout metadata={metadata}>
  <!-- 侧边栏 fixed：浮于主内容上方 -->
  {
    sidebarLinks.length > 0 && (
      <Sidebar
        groups={sidebarLinks.map(({ icon, ...rest }) => ({ ...rest, icon: icon ?? DEFAULT_ICON }))}
        currentPath={currentPath}
      />
    )
  }

  <!-- TopNav + 主内容统一偏移，避免被 fixed 侧边栏遮挡 -->
  <div data-main-content>
    <TopNav tabs={topTabs} currentPath={currentPath} />
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-16 md:py-20 lg:py-24">
      <slot />
    </div>
  </div>
</PageLayout>
