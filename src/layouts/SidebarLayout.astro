---
import PageLayout from '~/layouts/PageLayout.astro';
import TopNav from '~/components/widgets/TopNav.astro';
import Sidebar from '~/components/widgets/Sidebar.astro';

import type { MetaData } from '~/types';
import type { Tab } from '~/components/widgets/TopNav.astro';

export interface SidebarLink {
  text: string;
  href: string;
  icon?: string;
}

export interface Props {
  metadata?: MetaData;
  /** 全局顶栏标签 */
  topTabs?: Tab[];
  /** 当前分区侧边栏链接 */
  sidebarLinks?: SidebarLink[];
  currentPath?: string;
}

const { metadata, topTabs = [], sidebarLinks = [], currentPath = '' } = Astro.props;
---

<PageLayout metadata={metadata}>
  <TopNav tabs={topTabs} currentPath={currentPath} />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-[80px]">
    <div class="flex flex-col md:flex-row gap-8">
      <!-- Sidebar -->
      {
        sidebarLinks.length > 0 && (
          <aside class="hidden md:block md:w-64 shrink-0">
            <Sidebar links={sidebarLinks} currentPath={currentPath} />
          </aside>
        )
      }

      <!-- Main content -->
      <div class="flex-1 min-w-0">
        <slot />
      </div>
    </div>
  </div>
</PageLayout>
