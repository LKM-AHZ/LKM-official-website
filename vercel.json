{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/index.py": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/index" }],
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
